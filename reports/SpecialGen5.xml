<?xml version="1.0" encoding="iso-8859-1"?>
<!DOCTYPE report PUBLIC "-//JFreeReport//DTD report definition//EN//simple"
                        "http://jfreereport.sourceforge.net/report.dtd">

<!-- Changing this file will effect all reports created with the Special Report generator.
If you ruin this file beyond all hope, just delete the file and 
the next time you create the report in Lazy8Ledger, then the file will 
automatically be recreated in its original form in the reports directory again
-->

<report name="Special generator report" orientation="portrait" topmargin="70" leftmargin="70" bottommargin="70" rightmargin="70">
    <reportheader height="100" fontname="SansSerif" fontstyle="bold" fontsize="9">
       <string-field  x="1" y="1" width="100%" height="16" alignment="left" fieldname="reporttitle" fontsize="16"/>
       <line name="linerepheadmiddle" x1="0" y1="18" x2="0" y2="18" weight="2.0"/>
       <image-field   x="250" y="21" width="100%" height="67" fieldname="iconheader" dynamic="false" keepAspectRatio="true" />
       <string-field  x="1"  y="19" width="118" height="10" alignment="left" fieldname="reportdate"/>
       <string-field  x="120" y="19" width="128" height="10" alignment="left" fieldname="dateToday"/>
       <string-field  x="1"  y="29" width="118" height="10" alignment="left" fieldname="companytext"/>
       <string-field  x="120" y="29" width="128" height="10" alignment="left" fieldname="company"/>
       <string-field  x="1"  y="39" width="118" height="10" alignment="left" fieldname="startdatetext"/>
       <string-field  x="120" y="39" width="128" height="10" alignment="left" fieldname="dateFrom"/>
       <string-field  x="1"  y="49" width="118" height="10" alignment="left" fieldname="stopdatetext"/>
       <string-field  x="120" y="49" width="128" height="10" alignment="left" fieldname="dateTo"/>
       <string-field  x="1"  y="59" width="118" height="10" alignment="left" fieldname="LastTransactionNumberText"/>
       <string-field  x="120" y="59" width="128" height="10" alignment="left" fieldname="LastTransactionNumber"/>
       <label  x="120" y="59" width="238" height="10" alignment="left" > </label>
       <line name="linerepheadbottom" x1="0" y1="90" x2="0" y2="90" weight="3.0"/>
    </reportheader>

    <reportfooter height="48" fontname="SansSerif" fontstyle="bold" fontsize="16">
    </reportfooter>

    <pageheader height="0" fontname="SansSerif" fontstyle="bold" fontsize="9">
    </pageheader>

    <pagefooter height="18">
      <string-field fieldname="pageXofY" x="50%" y="4" width="100%" height="18" alignment="right"/>
      <string-field fieldname="dateToday" x="0" y="4" width="100" height="18" alignment="left"/>
    </pagefooter>

    <groups>
        <group name="Grouping Level 1">
            <groupheader height="16" fontname="SansSerif" fontstyle="plain" fontsize="14" pagebreak="false">
                <string-field  x="1" y="1" width="100%" height="16" alignment="left" fieldname="GROUP2"/>
            </groupheader>
            <groupfooter height="30" fontname="SansSerif" fontstyle="bold" fontsize="8">
                <line name="line1" x1="225" y1="0" x2="475" y2="0" weight="3.0"/>
                <string-field  x="60" y="3" width="164" height="10" alignment="left" fieldname="GROUP2" />
                <string-field x="225" y="3" width="75" height="10" alignment="right" fieldname="FReportIncommingSum"/>
                <string-field x="300" y="3" width="75" height="10" alignment="right" fieldname="FReportAmountSum"/>
                <string-field x="375" y="3" width="75" height="10" alignment="right" fieldname="FReportOutgoingSum"/>
                <line name="line1" x1="225" y1="15" x2="475" y2="15" weight="3.0"/>
                <string-field  x="60" y="18" width="164" height="10" alignment="left" fieldname="reporttotal" />
                <string-field x="225" y="18" width="75" height="10" alignment="right" fieldname="FWholeIncommingSum"/>
                <string-field x="300" y="18" width="75" height="10" alignment="right" fieldname="FWholeAmountSum"/>
                <string-field x="375" y="18" width="75" height="10" alignment="right" fieldname="FWholeOutgoingSum"/>
            </groupfooter>
            <fields>
                 <field>GROUP2</field>
            </fields>
        </group>
        <group name="Grouping Level 2">
            <groupheader height="33" fontname="SansSerif" fontstyle="bold" fontsize="6" pagebreak="false">
                <string-field  x="10" y="1" width="100%" height="16" alignment="left" fieldname="GROUP1" fontsize="12" />
                <string-field  x="20" y="22" width="39" height="7" alignment="left" fieldname="accnum" />
                <string-field  x="60" y="22" width="164" height="7" alignment="left" fieldname="accname" />
                <string-field  x="225" y="22" width="75" height="7" alignment="right" fieldname="incomming" />
                <string-field  x="300" y="22" width="75" height="7" alignment="right" fieldname="amount" />
                <string-field  x="375" y="22" width="75" height="7" alignment="right" fieldname="outgoing" />
            </groupheader>
            <groupfooter height="15" fontname="SansSerif" fontstyle="plain" fontsize="8">
                <line name="line1" x1="225" y1="0" x2="475" y2="0" weight="0.5"/>
                <string-field  x="60" y="3" width="164" height="10" alignment="left" fieldname="GROUP1" />
                <string-field x="225" y="3" width="75" height="10" alignment="right" fieldname="FIncommingSum"/>
                <string-field x="300" y="3" width="75" height="10" alignment="right" fieldname="FAmountSum"/>
                <string-field x="375" y="3" width="75" height="10" alignment="right" fieldname="FOutgoingSum"/>
            </groupfooter>
            <fields>
                 <field>GROUP2</field>
                 <field>GROUP1</field>
            </fields>
        </group>
    </groups>

    <items height="10" fontname="SansSerif" fontstyle="plain" fontsize="8">
    <!-- the rectangle is named as it is referenced later in the function section -->
<!--  Include these next rows if you want banding with colorful lines
    <rectangle name="background" x="20" y="0" width="100%" height="100%" color="#DFDFDF" weight="0"/>
    <line x1="20" y1="10" x2="450" y2="10" color="#FF0FFF" weight="0.1"/>
    <line x1="20" y1="0" x2="450" y2="0" color="#FF0FFF" weight="0.1"/>
-->
        <string-field x="20" y="0" width="40" height="10" alignment="left" fieldname="ACCOUNTNUM" />
        <string-field x="60" y="0" width="164" height="10" alignment="left" fieldname="ACCOUNTDESC" />
        <string-field x="225" y="0" width="75" height="10" alignment="right" fieldname="FORMATED_INCOMMINGAMOUNT" />
        <string-field x="300" y="0" width="75" height="10" alignment="right" fieldname="FORMATED_AMOUNT" />
        <string-field x="375" y="0" width="75" height="10" alignment="right" fieldname="FORMATED_OUTGOINGAMOUNT" />
    </items>

    <functions>
    <!-- WARNING!!!! FontChangeFunction will change all the font names in this report!!!!!!!!  
    Remove this function if you want to customize the font names-->
    <function name="fontmod" class="nu.lazy8.util.help.FontChangeFunction" />

    <function name="IncommingSum" class="org.jfree.report.function.TotalGroupSumFunction">
      <properties>
        <property name="field">INCOMMINGAMOUNT</property>
        <property name="group">Grouping Level 2</property>
      </properties>
    </function>
    <function name="AmountSum" class="org.jfree.report.function.TotalGroupSumFunction">
      <properties>
        <property name="field">AMOUNT</property>
        <property name="group">Grouping Level 2</property>
      </properties>
    </function>
    <function name="OutgoingSum" class="org.jfree.report.function.TotalGroupSumFunction">
      <properties>
        <property name="field">OUTGOINGAMOUNT</property>
        <property name="group">Grouping Level 2</property>
      </properties>
    </function>
    
    <expression name="FIncommingSum" class="nu.lazy8.util.help.DoubleExpression">
      <properties>
        <property name="doublevalue">IncommingSum</property>
      </properties>
    </expression>
    <expression name="FAmountSum" class="nu.lazy8.util.help.DoubleExpression">
      <properties>
        <property name="doublevalue">AmountSum</property>
      </properties>
    </expression>
    <expression name="FOutgoingSum" class="nu.lazy8.util.help.DoubleExpression">
      <properties>
        <property name="doublevalue">OutgoingSum</property>
      </properties>
    </expression>
    
    <function name="ReportIncommingSum" class="org.jfree.report.function.TotalGroupSumFunction">
      <properties>
        <property name="field">INCOMMINGAMOUNT</property>
        <property name="group">Grouping Level 1</property>
      </properties>
    </function>
    <function name="ReportAmountSum" class="org.jfree.report.function.TotalGroupSumFunction">
      <properties>
        <property name="field">AMOUNT</property>
        <property name="group">Grouping Level 1</property>
      </properties>
    </function>
    <function name="ReportOutgoingSum" class="org.jfree.report.function.TotalGroupSumFunction">
      <properties>
        <property name="field">OUTGOINGAMOUNT</property>
        <property name="group">Grouping Level 1</property>
      </properties>
    </function>
    
    <expression name="FReportIncommingSum" class="nu.lazy8.util.help.DoubleExpression">
      <properties>
        <property name="doublevalue">ReportIncommingSum</property>
      </properties>
    </expression>
    <expression name="FReportAmountSum" class="nu.lazy8.util.help.DoubleExpression">
      <properties>
        <property name="doublevalue">ReportAmountSum</property>
      </properties>
    </expression>
    <expression name="FReportOutgoingSum" class="nu.lazy8.util.help.DoubleExpression">
      <properties>
        <property name="doublevalue">ReportOutgoingSum</property>
      </properties>
    </expression>

    <function name="WholeIncommingSum" class="org.jfree.report.function.ItemSumFunction">
      <properties>
        <property name="field">INCOMMINGAMOUNT</property>
      </properties>
    </function>
    <function name="WholeAmountSum" class="org.jfree.report.function.ItemSumFunction">
      <properties>
        <property name="field">AMOUNT</property>
      </properties>
    </function>
    <function name="WholeOutgoingSum" class="org.jfree.report.function.ItemSumFunction">
      <properties>
        <property name="field">OUTGOINGAMOUNT</property>
      </properties>
    </function>
    
    <expression name="FWholeIncommingSum" class="nu.lazy8.util.help.DoubleExpression">
      <properties>
        <property name="doublevalue">WholeIncommingSum</property>
      </properties>
    </expression>
    <expression name="FWholeAmountSum" class="nu.lazy8.util.help.DoubleExpression">
      <properties>
        <property name="doublevalue">WholeAmountSum</property>
      </properties>
    </expression>
    <expression name="FWholeOutgoingSum" class="nu.lazy8.util.help.DoubleExpression">
      <properties>
        <property name="doublevalue">WholeOutgoingSum</property>
      </properties>
    </expression>

    <function name="backgroundTrigger" class="org.jfree.report.function.ElementVisibilitySwitchFunction">
      <properties>
        <property name="element">background</property>
      </properties>
    </function>


    <function name="PageNumber" class="org.jfree.report.function.PageFunction"/>
    <function name="PageTotal" class="org.jfree.report.function.PageTotalFunction"/>
      <expression name="pageXofY" class="org.jfree.report.function.TextFormatExpression">
        <properties>
          <property name="pattern">Page {0} ({1})</property>
          <property name="0">PageNumber</property>
          <property name="1">PageTotal</property>
        </properties>
      </expression>
      <property-ref name="dateFrom"/>
      <property-ref name="dateTo"/>
      <property-ref name="dateToday"/>
      <property-ref name="reporttitle"/>
      <property-ref name="company"/>
      <property-ref name="companytext"/>
      <property-ref name="startdatetext"/>
      <property-ref name="stopdatetext"/>
      <property-ref name="accnum"/>
      <property-ref name="accname"/>
      <property-ref name="incomming"/>
      <property-ref name="amount"/>
      <property-ref name="outgoing"/>
      <property-ref name="iconheader"/>
      <property-ref name="reportdate"/>
      <property-ref name="reporttotal"/>
      <property-ref name="LastTransactionNumberText"/>
      <property-ref name="LastTransactionNumber"/>
    </functions>
</report>
