<?xml version="1.0" encoding="iso-8859-1"?>
<!DOCTYPE report PUBLIC "-//JFreeReport//DTD report definition//EN//simple"
                        "http://jfreereport.sourceforge.net/report.dtd">

<!-- Changing this file will change the Customer Transactions report layout.
If you ruin this file beyond all hope, just delete the file and 
the next time you create the report in Lazy8Ledger, then the file will 
automatically be recreated in its original form in the reports directory again
-->

<report name="Customer Transactions" orientation="portrait" topmargin="70" leftmargin="70" bottommargin="70" rightmargin="70">
    <reportheader height="120" fontname="SansSerif" fontstyle="bold" fontsize="9">
       <string-field  x="35%" y="1" width="65%" height="16" alignment="right" fieldname="custtransreport" fontsize="14"/>
       <string-field  x="1" y="1" width="34%" height="16" alignment="left" fieldname="reporttitle" fontsize="14"/>
       <line name="linerepheadmiddle" x1="0" y1="18" x2="0" y2="18" weight="2.0"/>
       <image-field   x="260" y="20" width="100%" height="67" fieldname="iconheader" dynamic="false" keepAspectRatio="true" />
       <string-field  x="1"  y="19" width="128" height="10" alignment="left" fieldname="reportdate"/>
       <string-field  x="129" y="19" width="128" height="10" alignment="left" fieldname="dateToday"/>
       <string-field  x="1"  y="29" width="128" height="10" alignment="left" fieldname="companytext"/>
       <string-field  x="129" y="29" width="128" height="10" alignment="left" fieldname="company"/>
       <string-field  x="1"  y="39" width="128" height="10" alignment="left" fieldname="startdatetext"/>
       <string-field  x="129" y="39" width="128" height="10" alignment="left" fieldname="dateFrom"/>
       <string-field  x="1"  y="49" width="128" height="10" alignment="left" fieldname="stopdatetext"/>
       <string-field  x="129" y="49" width="128" height="10" alignment="left" fieldname="dateTo"/>
       <string-field  x="1"  y="59" width="128" height="10" alignment="left" fieldname="customer"/>
       <string-field  x="129"  y="59" width="128" height="10" alignment="left" fieldname="selectedcustomer"/>
       <string-field  x="1"  y="69" width="128" height="10" alignment="left" fieldname="transfromtext"/>
       <string-field  x="129"  y="69" width="128" height="10" alignment="left" fieldname="transfrom"/>
       <string-field  x="1"  y="79" width="128" height="10" alignment="left" fieldname="transtotext"/>
       <string-field  x="129"  y="79" width="128" height="10" alignment="left" fieldname="transto"/>
       <string-field  x="1"  y="89" width="128" height="10" alignment="left" fieldname="LastTransactionNumberText"/>
       <string-field  x="129" y="89" width="128" height="10" alignment="left" fieldname="LastTransactionNumber"/>
       <label  x="120" y="79" width="238" height="10" alignment="left" > </label>
       <line name="linerepheadbottom" x1="0" y1="100" x2="0" y2="100" weight="3.0"/>
    </reportheader>

    <reportfooter height="48" fontname="SansSerif" fontstyle="bold" fontsize="16">
    </reportfooter>

    <pageheader height="0" fontname="SansSerif" fontstyle="bold" fontsize="9">
    </pageheader>

    <pagefooter height="18">
      <string-field fieldname="pageXofY" x="50%" y="4" width="100%" height="18" alignment="right"/>
      <string-field fieldname="dateToday" x="0" y="4" width="100" height="18" alignment="left"/>
    </pagefooter>

    <groups>
        <group name="Customer Group">
            <groupheader height="32" fontname="SansSerif" fontstyle="plain" fontsize="12" pagebreak="false">
                <string-field x="0" y="5" width="39" height="12" alignment="left" fieldname="CUSTOMERNUM" />
                <string-field x="40" y="5" width="100%" height="12" alignment="left" fieldname="CUSTOMER" />
                <string-field  x="0" y="19" width="29" height="7" alignment="left" fieldname="act_id" fontstyle="bold" fontsize="6"/>
                <string-field  x="30" y="19" width="54" height="7" alignment="left" fieldname="invdate" fontstyle="bold" fontsize="6"/>
                <string-field  x="85" y="19" width="69" height="7" alignment="left" fieldname="comment" fontstyle="bold" fontsize="6"/>
                <string-field  x="155" y="19" width="59" height="7" alignment="left" fieldname="comment" fontstyle="bold" fontsize="6"/>
                <string-field  x="215" y="19" width="29" height="7" alignment="left" fieldname="accnum" fontstyle="bold" fontsize="6"/>
                <string-field  x="245" y="19" width="90" height="7" alignment="left" fieldname="accname" fontstyle="bold" fontsize="6"/>
                <string-field  x="335" y="19" width="69" height="7" alignment="right" fieldname="debit" fontstyle="bold" fontsize="6"/>
                <string-field  x="405" y="19" width="69" height="7" alignment="right" fieldname="credit" fontstyle="bold" fontsize="6"/>
                <line name="line1" x1="0" y1="27" x2="0" y2="27" weight="0.5"/>
            </groupheader>
            <groupfooter height="25" fontname="SansSerif" fontstyle="plain" fontsize="7">
                <line name="line1" x1="100" y1="0" x2="475" y2="0" weight="2.0"/>
                <string-field x="100" y="3" width="99" height="8" alignment="left" fieldname="CUSTOMER" />
                <string-field x="200" y="3" width="59" height="8" alignment="right" fieldname="Total"/>
                <string-field x="260" y="3" width="74" height="8" alignment="right" fieldname="FCustomerBalanceSum"/>
                <label  x="0" y="14" width="100%" height="10" alignment="left" > </label>
            </groupfooter>
            <fields>
                 <field>CUSTOMERNUM</field>
            </fields>
        </group>
        <group name="Account Group">
<!--  Not needed.  Looks better without...
            <groupheader height="32" fontname="SansSerif" fontstyle="plain" fontsize="10" pagebreak="false">
                <string-field x="0" y="0" width="39" height="10" alignment="left" fieldname="ACCOUNTNUM" />
                <string-field x="40" y="0" width="100%" height="10" alignment="left" fieldname="ACCOUNTNAME" />
                <line name="line1" x1="0" y1="17" x2="0" y2="17" weight="2.0"/>
            </groupheader>
-->
            <groupfooter height="25" fontname="SansSerif" fontstyle="plain" fontsize="7">
                <line name="line1" x1="300" y1="0" x2="475" y2="0" weight="2.0"/>
                <string-field x="0" y="3" width="99" height="8" alignment="left" fieldname="CUSTOMER" />
                <string-field x="100" y="3" width="99" height="8" alignment="left" fieldname="ACCOUNTNAME" />
                <string-field x="200" y="3" width="59" height="8" alignment="right" fieldname="Balance"/>
                <string-field x="260" y="3" width="74" height="8" alignment="right" fieldname="FBalanceSum"/>
                <string-field x="335" y="3" width="69" height="8" alignment="right" fieldname="FDebitSum"/>
                <string-field x="405" y="3" width="69" height="8" alignment="right" fieldname="FCreditSum"/>
                <label  x="0" y="14" width="100%" height="10" alignment="left" > </label>
            </groupfooter>
            <fields>
                 <field>CUSTOMERNUM</field>
                 <field>ACCOUNTNUM</field>
            </fields>
        </group>
    </groups>

    <items height="10" fontname="SansSerif" fontstyle="plain" fontsize="7">
        <string-field x="0" y="0" width="29" height="8" alignment="left" fieldname="ACT_ID" />
        <string-field x="30" y="0" width="54" height="8" alignment="left" fieldname="INVDATE" />
        <string-field x="85" y="0" width="69" height="8" alignment="left" fieldname="COMMENTALL" />
        <string-field x="155" y="0" width="59" height="8" alignment="left" fieldname="COMMENT" />
        <string-field x="215" y="0" width="29" height="8" alignment="left" fieldname="ACCOUNTNUM" />
        <string-field x="245" y="0" width="90" height="8" alignment="left" fieldname="ACCOUNTNAME" />
        <string-field x="335" y="0" width="69" height="8" alignment="right" fieldname="DEBITFORMAT" />
        <string-field x="405" y="0" width="69" height="8" alignment="right" fieldname="CREDITFORMAT" />
    </items>

    <functions>
    <!-- WARNING!!!! FontChangeFunction will change all the font names in this report!!!!!!!!  
    Remove this function if you want to customize the font names-->
    <function name="fontmod" class="nu.lazy8.util.help.FontChangeFunction" />

    <function name="DebitSum" class="org.jfree.report.function.TotalGroupSumFunction">
      <properties>
        <property name="field">DEBIT</property>
        <property name="group">Account Group</property>
      </properties>
    </function>
    <function name="CreditSum" class="org.jfree.report.function.TotalGroupSumFunction">
      <properties>
        <property name="field">CREDIT</property>
        <property name="group">Account Group</property>
      </properties>
    </function>
    
    <expression name="FCreditSum" class="nu.lazy8.util.help.DoubleExpression">
      <properties>
        <property name="doublevalue">CreditSum</property>
      </properties>
    </expression>
    <expression name="FDebitSum" class="nu.lazy8.util.help.DoubleExpression">
      <properties>
        <property name="doublevalue">DebitSum</property>
      </properties>
    </expression>
    
    <function name="BalanceSum" class="org.jfree.report.function.TotalGroupSumFunction">
      <properties>
        <property name="field">SUMMING_FIELD</property>
        <property name="group">Account Group</property>
      </properties>
    </function>
    <expression name="FBalanceSum" class="nu.lazy8.util.help.DoubleExpression">
      <properties>
        <property name="doublevalue">BalanceSum</property>
      </properties>
    </expression>
    <function name="CustomerBalanceSum" class="org.jfree.report.function.TotalGroupSumFunction">
      <properties>
        <property name="field">SUMMING_FIELD</property>
        <property name="group">Customer Group</property>
      </properties>
    </function>
    <expression name="FCustomerBalanceSum" class="nu.lazy8.util.help.DoubleExpression">
      <properties>
        <property name="doublevalue">CustomerBalanceSum</property>
      </properties>
    </expression>
   
    <function name="PageNumber" class="org.jfree.report.function.PageFunction"/>
    <function name="PageTotal" class="org.jfree.report.function.PageTotalFunction"/>
      <expression name="pageXofY" class="org.jfree.report.function.TextFormatExpression">
        <properties>
          <property name="pattern">Page {0} ({1})</property>
          <property name="0">PageNumber</property>
          <property name="1">PageTotal</property>
        </properties>
      </expression>
      <property-ref name="dateFrom"/>
      <property-ref name="dateTo"/>
      <property-ref name="dateToday"/>
      <property-ref name="reporttitle"/>
      <property-ref name="company"/>
      <property-ref name="companytext"/>
      <property-ref name="startdatetext"/>
      <property-ref name="stopdatetext"/>
      <property-ref name="custtransreport"/>
      <property-ref name="act_id"/>
      <property-ref name="invdate"/>
      <property-ref name="comment"/>
      <property-ref name="accnum"/>
      <property-ref name="accname"/>
      <property-ref name="customer"/>
      <property-ref name="debit"/>
      <property-ref name="credit"/>
      <property-ref name="iconheader"/>
      <property-ref name="reportdate"/>
      <property-ref name="selectedaccount"/>
      <property-ref name="selectedcustomer"/>
      <property-ref name="transfromtext"/>
      <property-ref name="transtotext"/>
      <property-ref name="transfrom"/>
      <property-ref name="transto"/>
      <property-ref name="LastTransactionNumberText"/>
      <property-ref name="LastTransactionNumber"/>
      <property-ref name="Balance"/>
      <property-ref name="Total"/>
    </functions>
</report>
