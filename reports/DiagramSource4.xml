<?xml version="1.0" encoding="iso-8859-1"?>
<!DOCTYPE report PUBLIC "-//JFreeReport//DTD report definition//EN//simple"
                        "http://jfreereport.sourceforge.net/report.dtd">

<!-- Changing this file will change all reports that are created from a diagram.
If you ruin this file beyond all hope, just delete the file and 
the next time you create the report in Lazy8Ledger, then the file will 
automatically be recreated in its original form in the reports directory again
-->

<report name="Diagram source" orientation="portrait" topmargin="70" leftmargin="70" bottommargin="70" rightmargin="70">
    <reportheader height="45" fontname="SansSerif" fontstyle="bold" fontsize="9">
       <string-field  x="1" y="1" width="100%" height="17" alignment="left" fieldname="diagramreport" fontsize="16"/>
       <line name="linerepheadmiddle" x1="0" y1="19" x2="0" y2="19" weight="2.0"/>
       <string-field  x="0" y="22" width="100%" height="10" alignment="left" fieldname="dateToday"/>
       <string-field  x="0" y="32" width="100%" height="10" alignment="left" fieldname="company"/>
       <label  x="1" y="42" width="100%" height="10" alignment="left" > </label>
       <line name="linerepbottom" x1="0" y1="52" x2="0" y2="52" weight="2.0"/>
    </reportheader>

    <reportfooter height="48" fontname="SansSerif" fontstyle="bold" fontsize="16">
    </reportfooter>

    <pageheader height="0" fontname="SansSerif" fontstyle="bold" fontsize="9">
    </pageheader>

    <pagefooter height="18">
      <string-field fieldname="pageXofY" x="50%" y="4" width="100%" height="18" alignment="right"/>
      <string-field fieldname="dateToday" x="0" y="4" width="100" height="18" alignment="left"/>
    </pagefooter>

    <groups>
        <group name="Account Group">
            <groupheader height="42" fontname="SansSerif" fontstyle="plain" fontsize="10" pagebreak="false">
                <string-field x="0" y="10" width="100%" height="10" alignment="left" fieldname="Series" />
                <line name="line1" x1="0" y1="37" x2="0" y2="37" weight="0.5"/>
                <string-field  x="0" y="29" width="149" height="7" alignment="left" fieldname="series" fontstyle="bold" fontsize="6"/>
                <string-field  x="150" y="29" width="149" height="7" alignment="left" fieldname="catagory" fontstyle="bold" fontsize="6"/>
                <string-field  x="300" y="29" width="100%" height="7" alignment="left" fieldname="value" fontstyle="bold" fontsize="6"/>
            </groupheader>
            <fields>
                 <field>Series</field>
            </fields>
        </group>
    </groups>

    <items height="10" fontname="SansSerif" fontstyle="plain" fontsize="8">
        <string-field x="0" y="0" width="149" height="8" alignment="left" fieldname="Series" />
        <string-field x="150" y="0" width="149" height="8" alignment="left" fieldname="Catagory" />
        <string-field x="300" y="0" width="100%" height="8" alignment="left" fieldname="Value" />
    </items>

    <functions>
    <!-- WARNING!!!! FontChangeFunction will change all the font names in this report!!!!!!!!  
    Remove this function if you want to customize the font names-->
    <function name="fontmod" class="nu.lazy8.util.help.FontChangeFunction" />

   
    <function name="PageNumber" class="org.jfree.report.function.PageFunction"/>
    <function name="PageTotal" class="org.jfree.report.function.PageTotalFunction"/>
      <expression name="pageXofY" class="org.jfree.report.function.TextFormatExpression">
        <properties>
          <property name="pattern">Page {0} ({1})</property>
          <property name="0">PageNumber</property>
          <property name="1">PageTotal</property>
        </properties>
      </expression>
      <property-ref name="diagramreport"/>
      <property-ref name="catagory"/>
      <property-ref name="value"/>
      <property-ref name="series"/>
      <property-ref name="company"/>
      <property-ref name="companytext"/>
      <property-ref name="dateToday"/>
    </functions>
</report>
