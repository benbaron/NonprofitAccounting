<?xml version="1.0" encoding="iso-8859-1"?>
<!DOCTYPE report PUBLIC "-//JFreeReport//DTD report definition//EN//simple"
                        "http://jfreereport.sourceforge.net/report.dtd">

<!-- Changing this file will change the Account summary report layout.
If you ruin this file beyond all hope, just delete the file and 
the next time you create the report in Lazy8Ledger, then the file will 
automatically be recreated in its original form in the reports directory again
-->

<report name="Account summary" orientation="portrait" topmargin="70" leftmargin="70" bottommargin="70" rightmargin="70">
    <reportheader height="110" fontname="SansSerif" fontstyle="bold" fontsize="9">
       <string-field  x="55%" y="1" width="45%" height="16" alignment="right" fieldname="accountreport" fontsize="16"/>
       <string-field  x="1" y="1" width="50%" height="16" alignment="left" fieldname="reporttitle" fontsize="16"/>
       <line name="linerepheadmiddle" x1="0" y1="18" x2="0" y2="18" weight="2.0"/>
       <image-field   x="250" y="20" width="100%" height="67" fieldname="iconheader" dynamic="false" keepAspectRatio="true" />
       <string-field  x="1"  y="19" width="118" height="10" alignment="left" fieldname="reportdate"/>
       <string-field  x="120" y="19" width="128" height="10" alignment="left" fieldname="dateToday"/>
       <string-field  x="1"  y="29" width="118" height="10" alignment="left" fieldname="companytext"/>
       <string-field  x="120" y="29" width="128" height="10" alignment="left" fieldname="company"/>
       <string-field  x="1"  y="39" width="118" height="10" alignment="left" fieldname="startdatetext"/>
       <string-field  x="120" y="39" width="128" height="10" alignment="left" fieldname="dateFrom"/>
       <string-field  x="1"  y="49" width="118" height="10" alignment="left" fieldname="stopdatetext"/>
       <string-field  x="120" y="49" width="128" height="10" alignment="left" fieldname="dateTo"/>
       <string-field  x="1"  y="59" width="118" height="10" alignment="left" fieldname="accnum"/>
       <string-field  x="120"  y="59" width="128" height="10" alignment="left" fieldname="selectedaccount"/>
       <string-field  x="1"  y="69" width="118" height="10" alignment="left" fieldname="customer"/>
       <string-field  x="120"  y="69" width="128" height="10" alignment="left" fieldname="selectedcustomer"/>
       <string-field  x="1"  y="79" width="118" height="10" alignment="left" fieldname="LastTransactionNumberText"/>
       <string-field  x="120" y="79" width="128" height="10" alignment="left" fieldname="LastTransactionNumber"/>
       <label  x="120" y="79" width="238" height="10" alignment="left" > </label>
       <line name="linerepheadbottom" x1="0" y1="90" x2="0" y2="90" weight="3.0"/>
    </reportheader>

    <reportfooter height="48" fontname="SansSerif" fontstyle="bold" fontsize="16">
    </reportfooter>

    <pageheader height="0" fontname="SansSerif" fontstyle="bold" fontsize="9">
    </pageheader>

    <pagefooter height="18">
      <string-field fieldname="pageXofY" x="50%" y="4" width="100%" height="18" alignment="right"/>
      <string-field fieldname="dateToday" x="0" y="4" width="100" height="18" alignment="left"/>
    </pagefooter>

    <groups>
        <group name="Account Group">
            <groupheader height="32" fontname="SansSerif" fontstyle="plain" fontsize="10" pagebreak="false">
                <string-field x="0" y="0" width="39" height="10" alignment="left" fieldname="ACCOUNTNUM" />
                <string-field x="40" y="0" width="100%" height="10" alignment="left" fieldname="ACCOUNTNAME" />
                <string-field  x="0" y="19" width="39" height="7" alignment="left" fieldname="act_id" fontstyle="bold" fontsize="6"/>
                <string-field  x="40" y="19" width="44" height="7" alignment="left" fieldname="invdate" fontstyle="bold" fontsize="6"/>
                <string-field  x="85" y="19" width="104" height="7" alignment="left" fieldname="comment" fontstyle="bold" fontsize="6"/>
                <string-field  x="190" y="19" width="69" height="7" alignment="left" fieldname="comment" fontstyle="bold" fontsize="6"/>
                <string-field  x="260" y="19" width="39" height="7" alignment="left" fieldname="customer" fontstyle="bold" fontsize="6"/>
                <string-field  x="300" y="19" width="76" height="7" alignment="right" fieldname="debit" fontstyle="bold" fontsize="6"/>
                <string-field  x="400" y="19" width="76" height="7" alignment="right" fieldname="credit" fontstyle="bold" fontsize="6"/>
                <line name="line1" x1="0" y1="27" x2="0" y2="27" weight="0.5"/>
            </groupheader>
            <groupfooter height="45" fontname="SansSerif" fontstyle="plain" fontsize="8">
                <line name="line1" x1="300" y1="0" x2="475" y2="0" weight="0.5"/>
                <string-field x="200" y="3" width="76" height="10" alignment="right" fieldname="Total"/>
                <string-field x="300" y="3" width="76" height="10" alignment="right" fieldname="FDebitSum"/>
                <string-field x="400" y="3" width="76" height="10" alignment="right" fieldname="FCreditSum"/>
                <label  x="0" y="14" width="100%" height="10" alignment="left" > </label>
                <string-field x="200" y="15" width="76" height="7" alignment="right" fieldname="incomming" fontstyle="bold" fontsize="6"/>
                <string-field x="300" y="15" width="76" height="7" alignment="right" fieldname="amount" fontstyle="bold" fontsize="6"/>
                <string-field x="400" y="15" width="76" height="7" alignment="right" fieldname="outgoing" fontstyle="bold" fontsize="6"/>
                <line name="line1" x1="200" y1="23" x2="475" y2="23" weight="0.5"/>
                <string-field x="200" y="26" width="76" height="10" alignment="right" fieldname="INCOMMINGAMOUNT"/>
                <string-field x="300" y="26" width="76" height="10" alignment="right" fieldname="FBalanceSum"/>
                <string-field x="400" y="26" width="76" height="10" alignment="right" fieldname="OUTGOINGAMOUNT"/>
            </groupfooter>
            <fields>
                 <field>ACCOUNTNUM</field>
            </fields>
        </group>
    </groups>

    <items height="10" fontname="SansSerif" fontstyle="plain" fontsize="8">
        <string-field x="0" y="0" width="39" height="8" alignment="left" fieldname="ACT_ID" />
        <string-field x="40" y="0" width="44" height="8" alignment="left" fieldname="INVDATE" />
        <string-field x="85" y="0" width="104" height="8" alignment="left" fieldname="COMMENTALL" />
        <string-field x="190" y="0" width="69" height="8" alignment="left" fieldname="COMMENT" />
        <string-field x="260" y="0" width="39" height="8" alignment="left" fieldname="CUSTOMER" />
        <string-field x="300" y="0" width="76" height="8" alignment="right" fieldname="DEBITFORMAT" />
        <string-field x="400" y="0" width="76" height="8" alignment="right" fieldname="CREDITFORMAT" />
    </items>

    <functions>
    <!-- WARNING!!!! FontChangeFunction will change all the font names in this report!!!!!!!!  
    Remove this function if you want to customize the font names-->
    <function name="fontmod" class="nu.lazy8.util.help.FontChangeFunction" />

    <function name="DebitSum" class="org.jfree.report.function.TotalGroupSumFunction">
      <properties>
        <property name="field">DEBIT</property>
        <property name="group">Account Group</property>
      </properties>
    </function>
    <function name="CreditSum" class="org.jfree.report.function.TotalGroupSumFunction">
      <properties>
        <property name="field">CREDIT</property>
        <property name="group">Account Group</property>
      </properties>
    </function>
    
    <expression name="FCreditSum" class="nu.lazy8.util.help.DoubleExpression">
      <properties>
        <property name="doublevalue">CreditSum</property>
      </properties>
    </expression>
    <expression name="FDebitSum" class="nu.lazy8.util.help.DoubleExpression">
      <properties>
        <property name="doublevalue">DebitSum</property>
      </properties>
    </expression>

    <function name="BalanceSum" class="org.jfree.report.function.TotalGroupSumFunction">
      <properties>
        <property name="field">BALANCE</property>
        <property name="group">Account Group</property>
      </properties>
    </function>
    
    <expression name="FBalanceSum" class="nu.lazy8.util.help.DoubleExpression">
      <properties>
        <property name="doublevalue">BalanceSum</property>
      </properties>
    </expression>
    
    <function name="PageNumber" class="org.jfree.report.function.PageFunction"/>
    <function name="PageTotal" class="org.jfree.report.function.PageTotalFunction"/>
      <expression name="pageXofY" class="org.jfree.report.function.TextFormatExpression">
        <properties>
          <property name="pattern">Page {0} ({1})</property>
          <property name="0">PageNumber</property>
          <property name="1">PageTotal</property>
        </properties>
      </expression>
      <property-ref name="dateFrom"/>
      <property-ref name="dateTo"/>
      <property-ref name="dateToday"/>
      <property-ref name="reporttitle"/>
      <property-ref name="company"/>
      <property-ref name="companytext"/>
      <property-ref name="startdatetext"/>
      <property-ref name="stopdatetext"/>
      <property-ref name="accountreport"/>
      <property-ref name="act_id"/>
      <property-ref name="invdate"/>
      <property-ref name="comment"/>
      <property-ref name="accnum"/>
      <property-ref name="accname"/>
      <property-ref name="customer"/>
      <property-ref name="debit"/>
      <property-ref name="credit"/>
      <property-ref name="iconheader"/>
      <property-ref name="reportdate"/>
      <property-ref name="selectedaccount"/>
      <property-ref name="selectedcustomer"/>
      <property-ref name="LastTransactionNumberText"/>
      <property-ref name="LastTransactionNumber"/>
      <property-ref name="Total"/>
      <property-ref name="incomming"/>
      <property-ref name="amount"/>
      <property-ref name="outgoing"/>
    </functions>
</report>
