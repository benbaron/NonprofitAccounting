<?xml version="1.0" encoding="UTF-8"?>
<jasperReport whenNoDataType="AllSectionsNoDetail"
    xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
       http://jasperreports.sourceforge.net/jasperreports
       http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="TrialBalanceReport"
    pageWidth="595" pageHeight="842"
    leftMargin="70" rightMargin="70"
    topMargin="70" bottomMargin="70"
    columnWidth="455">

  <!-- ============== FIELDS ============== -->
  <field name="iconheader"           class="java.lang.Object"/>
  <field name="reportdate"           class="java.lang.String"/>
  <field name="dateToday"            class="java.lang.String"/>
  <field name="companytext"          class="java.lang.String"/>
  <field name="company"              class="java.lang.String"/>
  <field name="startdatetext"        class="java.lang.String"/>
  <field name="dateFrom"             class="java.lang.String"/>
  <field name="stopdatetext"         class="java.lang.String"/>
  <field name="dateTo"               class="java.lang.String"/>
  <field name="transfromtext"        class="java.lang.String"/>
  <field name="transfrom"            class="java.lang.String"/>
  <field name="transtotext"          class="java.lang.String"/>
  <field name="transto"              class="java.lang.String"/>
  <field name="accnum"               class="java.lang.String"/>
  <field name="accname"              class="java.lang.String"/>
  <field name="incomming"            class="java.lang.Double"/>
  <field name="amount"               class="java.lang.Double"/>
  <field name="outgoing"             class="java.lang.Double"/>

  <!-- ============== TITLE (reportheader) ============== -->
  <title>
    <band height="130">
      <staticText>
        <reportElement x="100" y="1" width="200" height="16" />
        <text><![CDATA[Trial Balance Report]]></text>
      </staticText>
      <staticText>
        <reportElement x="1" y="1" width="200" height="16" />
        <text><![CDATA[Report Title]]></text>
      </staticText>
      <line>
        <reportElement x="0" y="18" width="455" height="2" forecolor="#000000"/>
      </line>
      <image>
        <reportElement x="250" y="21" width="100" height="67"/>
        <imageExpression><![CDATA[$F{iconheader}]]></imageExpression>
      </image>
      <textField>
        <reportElement x="1" y="19" width="118" height="10"/>
        <textFieldExpression><![CDATA[$F{reportdate}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="120" y="19" width="128" height="10"/>
        <textFieldExpression><![CDATA[$F{dateToday}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="1" y="29" width="118" height="10"/>
        <textFieldExpression><![CDATA[$F{companytext}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="120" y="29" width="128" height="10"/>
        <textFieldExpression><![CDATA[$F{company}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="1" y="39" width="118" height="10"/>
        <textFieldExpression><![CDATA[$F{startdatetext}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="120" y="39" width="128" height="10"/>
        <textFieldExpression><![CDATA[$F{dateFrom}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="1" y="49" width="118" height="10"/>
        <textFieldExpression><![CDATA[$F{stopdatetext}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="120" y="49" width="128" height="10"/>
        <textFieldExpression><![CDATA[$F{dateTo}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="1" y="59" width="118" height="10"/>
        <textFieldExpression><![CDATA[$F{transfromtext}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="120" y="59" width="128" height="10"/>
        <textFieldExpression><![CDATA[$F{transfrom}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="1" y="69" width="118" height="10"/>
        <textFieldExpression><![CDATA[$F{transtotext}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="120" y="69" width="128" height="10"/>
        <textFieldExpression><![CDATA[$F{transto}]]></textFieldExpression>
      </textField>
    </band>
  </title>

  <!-- ============== COLUMN HEADER ============== -->
  <columnHeader>
    <band height="20">
      <staticText>
        <reportElement x="0" y="0" width="39" height="10"/>
        <text><![CDATA[Acct #]]></text>
      </staticText>
      <staticText>
        <reportElement x="40" y="0" width="184" height="10"/>
        <text><![CDATA[Description]]></text>
      </staticText>
      <staticText>
        <reportElement x="225" y="0" width="74" height="10" textAlignment="Right"/>
        <text><![CDATA[In]]></text>
      </staticText>
      <staticText>
        <reportElement x="300" y="0" width="74" height="10" textAlignment="Right"/>
        <text><![CDATA[Amt]]></text>
      </staticText>
      <staticText>
        <reportElement x="375" y="0" width="74" height="10" textAlignment="Right"/>
        <text><![CDATA[Out]]></text>
      </staticText>
    </band>
  </columnHeader>

  <!-- ============== DETAIL ============== -->
  <detail>
    <band height="10">
      <textField>
        <reportElement x="0" y="0" width="39" height="8"/>
        <textFieldExpression><![CDATA[$F{accnum}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="40" y="0" width="184" height="8"/>
        <textFieldExpression><![CDATA[$F{accname}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="225" y="0" width="74" height="8" textAlignment="Right"/>
        <textFieldExpression><![CDATA[$F{incomming}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="300" y="0" width="74" height="8" textAlignment="Right"/>
        <textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="375" y="0" width="74" height="8" textAlignment="Right"/>
        <textFieldExpression><![CDATA[$F{outgoing}]]></textFieldExpression>
      </textField>
    </band>
  </detail>

  <!-- ============== PAGE FOOTER ============== -->
  <pageFooter>
    <band height="18">
      <textField>
        <reportElement x="50%" y="4" width="45%" height="18" textAlignment="Right"/>
        <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER} + " of " + $V{PAGE_COUNT}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="0" y="4" width="45%" height="18"/>
        <textFieldExpression><![CDATA[$F{dateToday}]]></textFieldExpression>
      </textField>
    </band>
  </pageFooter>

  <!-- ============== NO DATA ============== -->
  <noData>
    <band height="30">
      <staticText>
        <reportElement x="0" y="0" width="455" height="30"/>
        <text><![CDATA[No data available]]></text>
      </staticText>
    </band>
  </noData>

</jasperReport>
