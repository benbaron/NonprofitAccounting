<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="DEPR_DTL_8_ROWS_2SECTIONS" language="java" pageWidth="842" pageHeight="595" columnWidth="782"
    leftMargin="30" rightMargin="30" topMargin="20" bottomMargin="20" whenNoDataType="AllSectionsNoDetail">

    <!-- Styles -->
    <style name="Base" fontName="Garamond" fontSize="10"/>
    <style name="Header" style="Base" isBold="true" fontSize="12"/>
    <style name="ColHeader" style="Base" isBold="true" pdfFontName="Helvetica-Bold"/>
    <style name="Cell" style="Base"/>
    <style name="Number" style="Base" pdfFontName="Helvetica" hAlign="Right"/>

    <!-- Parameters -->
    <parameter name="P_ORG_NAME" class="java.lang.String"/>
    <parameter name="P_REPORT_TITLE" class="java.lang.String"/>

    <!-- Fields (purpose-based names) -->
    <field name="schedule" class="java.lang.String"/>
    <field name="assetName" class="java.lang.String"/>
    <field name="acquiredDate" class="java.lang.String"/>
    <field name="acquisitionCost" class="java.math.BigDecimal"/>
    <field name="priorDepreciation" class="java.math.BigDecimal"/>
    <field name="depreciationThisPeriod" class="java.math.BigDecimal"/>
    <field name="accumulatedDepreciation" class="java.math.BigDecimal"/>
    <field name="netBookValue" class="java.math.BigDecimal"/>
    <field name="notes" class="java.lang.String"/>

    <!-- Title -->
    <title>
        <band height="34">
            <textField>
                <reportElement style="Header" x="0" y="0" width="782" height="16"/>
                <textFieldExpression><![CDATA[$P{P_REPORT_TITLE} == null ? "Depreciation Detail" : $P{P_REPORT_TITLE}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement style="Cell" x="0" y="18" width="782" height="14"/>
                <textFieldExpression><![CDATA[$P{P_ORG_NAME} == null ? "" : $P{P_ORG_NAME}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- Column header -->
    <columnHeader>
        <band height="18">
            <staticText><reportElement style="ColHeader" x="0" y="0" width="170" height="18"/><text><![CDATA[Asset]]></text></staticText>
            <staticText><reportElement style="ColHeader" x="170" y="0" width="90" height="18"/><text><![CDATA[Acquired]]></text></staticText>
            <staticText><reportElement style="ColHeader" x="260" y="0" width="90" height="18"/><text><![CDATA[Cost]]></text></staticText>
            <staticText><reportElement style="ColHeader" x="350" y="0" width="90" height="18"/><text><![CDATA[Prior Dep]]></text></staticText>
            <staticText><reportElement style="ColHeader" x="440" y="0" width="90" height="18"/><text><![CDATA[Deprec This Pd]]></text></staticText>
            <staticText><reportElement style="ColHeader" x="530" y="0" width="90" height="18"/><text><![CDATA[Accum Dep]]></text></staticText>
            <staticText><reportElement style="ColHeader" x="620" y="0" width="90" height="18"/><text><![CDATA[Net Book]]></text></staticText>
            <staticText><reportElement style="ColHeader" x="710" y="0" width="72" height="18"/><text><![CDATA[Notes]]></text></staticText>
        </band>
    </columnHeader>

    <!-- Group by schedule (FIVE_YEAR / SEVEN_YEAR) -->
    <group name="ScheduleGroup">
        <groupExpression><![CDATA[$F{schedule}]]></groupExpression>
        <groupHeader>
            <band height="22">
                <textField>
                    <reportElement style="Header" x="0" y="2" width="782" height="18"/>
                    <textFieldExpression><![CDATA[$F{schedule} != null && $F{schedule}.equals("FIVE_YEAR") ? "5-Year Depreciation" : "7-Year Depreciation"]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
        <groupFooter>
            <band height="18">
                <staticText>
                    <reportElement style="ColHeader" x="350" y="0" width="170" height="18"/>
                    <text><![CDATA[Section Total (Deprec This Pd)]]></text>
                </staticText>
                <textField pattern="#,##0.00">
                    <reportElement style="Number" x="520" y="0" width="100" height="18"/>
                    <textFieldExpression><![CDATA[new java.math.BigDecimal($V{deprecSectionSum}.doubleValue())]]></textFieldExpression>
                </textField>
            </band>
        </groupFooter>
    </group>

    <!-- Variables -->
    <variable name="deprecSectionSum" class="java.lang.Double" resetType="Group" resetGroup="ScheduleGroup" calculation="Sum">
        <variableExpression><![CDATA[$F{depreciationThisPeriod} == null ? 0.0 : $F{depreciationThisPeriod}.doubleValue()]]></variableExpression>
    </variable>

    <variable name="deprecGrandSum" class="java.lang.Double" resetType="Report" calculation="Sum">
        <variableExpression><![CDATA[$F{depreciationThisPeriod} == null ? 0.0 : $F{depreciationThisPeriod}.doubleValue()]]></variableExpression>
    </variable>

    <!-- Detail row -->
    <detail>
        <band height="16">
            <textField><reportElement style="Cell" x="0" y="0" width="170" height="16"/><textFieldExpression><![CDATA[$F{assetName}]]></textFieldExpression></textField>
            <textField><reportElement style="Cell" x="170" y="0" width="90" height="16"/><textFieldExpression><![CDATA[$F{acquiredDate}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement style="Number" x="260" y="0" width="90" height="16"/><textFieldExpression><![CDATA[$F{acquisitionCost}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement style="Number" x="350" y="0" width="90" height="16"/><textFieldExpression><![CDATA[$F{priorDepreciation}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement style="Number" x="440" y="0" width="90" height="16"/><textFieldExpression><![CDATA[$F{depreciationThisPeriod}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement style="Number" x="530" y="0" width="90" height="16"/><textFieldExpression><![CDATA[$F{accumulatedDepreciation}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement style="Number" x="620" y="0" width="90" height="16"/><textFieldExpression><![CDATA[$F{netBookValue}]]></textFieldExpression></textField>
            <textField><reportElement style="Cell" x="710" y="0" width="72" height="16"/><textFieldExpression><![CDATA[$F{notes}]]></textFieldExpression></textField>
        </band>
    </detail>

    <!-- Summary -->
    <summary>
        <band height="20">
            <staticText><reportElement style="ColHeader" x="350" y="0" width="170" height="18"/><text><![CDATA[Grand Total (Deprec This Pd)]]></text></staticText>
            <textField pattern="#,##0.00">
                <reportElement style="Number" x="520" y="0" width="100" height="18"/>
                <textFieldExpression><![CDATA[new java.math.BigDecimal($V{deprecGrandSum}.doubleValue())]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>
