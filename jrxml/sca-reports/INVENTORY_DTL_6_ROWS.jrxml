<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="INVENTORY_DTL_6_ROWS" language="java"
              pageWidth="1714" pageHeight="906"
              columnWidth="1714" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">

    <!-- Parameters -->
    <parameter name="P_ORG_NAME" class="java.lang.String"/>
    <parameter name="P_REPORT_TITLE" class="java.lang.String"/>

    <!-- Styles -->
    <style name="Title" fontName="Garamond" fontSize="16" isBold="true"/>
    <style name="TableHeader" fontName="Garamond" fontSize="10" isBold="true"/>
    <style name="Cell" fontName="Garamond" fontSize="10"/>
    <style name="Numeric" style="Cell">
        <paragraph alignment="Right"/>
    </style>

    <!-- Fields (row-based bean properties) -->
    <field name="category" class="java.lang.String"/>
    <field name="itemDescription" class="java.lang.String"/>
    <field name="skuOrId" class="java.lang.String"/>
    <field name="unit" class="java.lang.String"/>
    <field name="quantityStart" class="java.math.BigDecimal"/>
    <field name="quantityAdditions" class="java.math.BigDecimal"/>
    <field name="quantityReductions" class="java.math.BigDecimal"/>
    <field name="quantityEnd" class="java.math.BigDecimal"/>
    <field name="unitCost" class="java.math.BigDecimal"/>
    <field name="endingValue" class="java.math.BigDecimal"/>
    <field name="notes" class="java.lang.String"/>

    <!-- Title -->
    <title>
        <band height="60">
            <staticText>
                <reportElement x="20" y="10" width="1000" height="24" style="Title"/>
                <text><![CDATA[$P{P_ORG_NAME}]]></text>
            </staticText>
            <staticText>
                <reportElement x="20" y="34" width="1000" height="20" style="Title"/>
                <text><![CDATA[Inventory Detail (6)]]></text>
            </staticText>
        </band>
    </title>

    <!-- Column headers -->
    <columnHeader>
        <band height="28">
            <staticText><reportElement x="20"  y="6" width="140" height="20" style="TableHeader"/><text><![CDATA[Category]]></text></staticText>
            <staticText><reportElement x="160" y="6" width="370" height="20" style="TableHeader"/><text><![CDATA[Item Description]]></text></staticText>
            <staticText><reportElement x="530" y="6" width="100" height="20" style="TableHeader"/><text><![CDATA[SKU/ID]]></text></staticText>
            <staticText><reportElement x="630" y="6" width="70"  height="20" style="TableHeader"/><text><![CDATA[Unit]]></text></staticText>
            <staticText><reportElement x="700" y="6" width="90"  height="20" style="TableHeader"/><text><![CDATA[Begin Qty]]></text></staticText>
            <staticText><reportElement x="790" y="6" width="90"  height="20" style="TableHeader"/><text><![CDATA[Additions]]></text></staticText>
            <staticText><reportElement x="880" y="6" width="90"  height="20" style="TableHeader"/><text><![CDATA[Reductions]]></text></staticText>
            <staticText><reportElement x="970" y="6" width="90"  height="20" style="TableHeader"/><text><![CDATA[End Qty]]></text></staticText>
            <staticText><reportElement x="1060" y="6" width="110" height="20" style="TableHeader"/><text><![CDATA[Unit Cost]]></text></staticText>
            <staticText><reportElement x="1170" y="6" width="140" height="20" style="TableHeader"/><text><![CDATA[Ending Value]]></text></staticText>
            <staticText><reportElement x="1310" y="6" width="380" height="20" style="TableHeader"/><text><![CDATA[Notes]]></text></staticText>
        </band>
    </columnHeader>

    <!-- Detail rows -->
    <detail>
        <band height="22" splitType="Stretch">
            <textField isStretchWithOverflow="true">
                <reportElement x="20"  y="2" width="140" height="18" style="Cell"/>
                <textFieldExpression><![CDATA[$F{category}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="160" y="2" width="370" height="18" style="Cell"/>
                <textFieldExpression><![CDATA[$F{itemDescription}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="530" y="2" width="100" height="18" style="Cell"/>
                <textFieldExpression><![CDATA[$F{skuOrId}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="630" y="2" width="70" height="18" style="Cell"/>
                <textFieldExpression><![CDATA[$F{unit}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.###" >
                <reportElement x="700" y="2" width="90" height="18" style="Numeric"/>
                <textFieldExpression><![CDATA[$F{quantityStart}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.###" >
                <reportElement x="790" y="2" width="90" height="18" style="Numeric"/>
                <textFieldExpression><![CDATA[$F{quantityAdditions}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.###" >
                <reportElement x="880" y="2" width="90" height="18" style="Numeric"/>
                <textFieldExpression><![CDATA[$F{quantityReductions}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.###" >
                <reportElement x="970" y="2" width="90" height="18" style="Numeric"/>
                <textFieldExpression><![CDATA[$F{quantityEnd}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="1060" y="2" width="110" height="18" style="Numeric"/>
                <textFieldExpression><![CDATA[$F{unitCost}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="1170" y="2" width="140" height="18" style="Numeric"/>
                <textFieldExpression><![CDATA[$F{endingValue}]]></textFieldExpression>
            </textField>
            <textField isStretchWithOverflow="true">
                <reportElement x="1310" y="2" width="380" height="18" style="Cell"/>
                <textFieldExpression><![CDATA[$F{notes}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- Summary (optional totals) -->
    <summary>
        <band height="40">
            <staticText>
                <reportElement x="970" y="10" width="200" height="18" style="TableHeader"/>
                <text><![CDATA[Total Ending Value]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="1170" y="10" width="140" height="18" style="Numeric"/>
                <textFieldExpression><![CDATA[new java.math.BigDecimal(0)]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>
