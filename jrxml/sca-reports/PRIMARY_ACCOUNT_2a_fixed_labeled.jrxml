<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="PrimaryAccountReconciliationFlatStyled" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">
    <style name="PairedLabel" fontName="Garamond" fontSize="10" isBold="true" />
    <style name="PairedValue" fontName="Garamond" fontSize="10" />

    <!-- Fields (flattened as before) -->
    <field name="bankName" class="java.lang.String"/>
    <field name="bankAccountTitle" class="java.lang.String"/>
    <field name="bankAccountType" class="java.lang.String"/>
    <field name="bankAccountNumber" class="java.lang.String"/>
    <field name="bankBranchPhoneAndName" class="java.lang.String"/>

    <field name="balanceFromBankStatement" class="java.math.BigDecimal"/>

    <!-- Deposits (6 slots) -->
    <field name="deposit1Date" class="java.lang.String"/>
    <field name="deposit1Amount" class="java.math.BigDecimal"/>
    <field name="deposit2Date" class="java.lang.String"/>
    <field name="deposit2Amount" class="java.math.BigDecimal"/>
    <field name="deposit3Date" class="java.lang.String"/>
    <field name="deposit3Amount" class="java.math.BigDecimal"/>
    <field name="deposit4Date" class="java.lang.String"/>
    <field name="deposit4Amount" class="java.math.BigDecimal"/>
    <field name="deposit5Date" class="java.lang.String"/>
    <field name="deposit5Amount" class="java.math.BigDecimal"/>
    <field name="deposit6Date" class="java.lang.String"/>
    <field name="deposit6Amount" class="java.math.BigDecimal"/>

    <!-- Checks (showing first two for pattern; replicate through check16) -->
    <field name="check1Number" class="java.lang.String"/>
    <field name="check1Date" class="java.lang.String"/>
    <field name="check1Amount" class="java.math.BigDecimal"/>

    <field name="check2Number" class="java.lang.String"/>
    <field name="check2Date" class="java.lang.String"/>
    <field name="check2Amount" class="java.math.BigDecimal"/>
    <!-- ... repeat up through check16Number / Date / Amount -->

    <field name="endingLedgerOrRegisterBalance" class="java.math.BigDecimal"/>
    <field name="accountEarnsInterest" class="java.lang.String"/>

    <!-- Totals / computed values (precomputed by filler) -->
    <field name="depositsNotClearedTotal" class="java.math.BigDecimal"/>
    <field name="checksNotClearedTotal" class="java.math.BigDecimal"/>
    <field name="adjustedAccountBalance" class="java.math.BigDecimal"/>
    <field name="reconciliationDifference" class="java.math.BigDecimal"/>

    <!-- Styles extracted from sheet -->
    <style name="TitleStyle">
        <font fontName="Garamond" size="14" isBold="true"/>
    </style>
    <style name="SectionHeader">
        <font fontName="Garamond" size="10" isBold="true"/>
    </style>
    <style name="LabelBold">
        <font fontName="Garamond" size="10" isBold="true"/>
    </style>
    <style name="Value">
        <font fontName="Garamond" size="10"/>
    </style>
    <style name="FormulaValue">
        <font fontName="Calibri" size="11"/>
    </style>

    <!-- Title / Header -->
    <title>
        <band height="70">
            <staticText>
                <reportElement x="0" y="0" width="555" height="20"/>
                <textElement textAlignment="Center">
                    <font fontName="Garamond" size="14" isBold="true"/>
                </textElement>
                <text><![CDATA[PRIMARY ACCOUNT RECONCILIATION]]></text>
            </staticText>

            <!-- Bank info block -->
            <staticText>
                <reportElement x="0" y="25" width="120" height="12"/>
                <textElement>
                    <font fontName="Garamond" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Bank Name:]]></text>
            </staticText>
            <textField>
                <reportElement x="125" y="25" width="200" height="12"/>
                <textElement>
                    <font fontName="Garamond" size="10"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{bankName}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="40" width="120" height="12"/>
                <textElement>
                    <font fontName="Garamond" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Account Title:]]></text>
            </staticText>
            <textField>
                <reportElement x="125" y="40" width="200" height="12"/>
                <textFieldExpression><![CDATA[$F{bankAccountTitle}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="55" width="120" height="12"/>
                <textElement>
                    <font fontName="Garamond" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Account Type:]]></text>
            </staticText>
            <textField>
                <reportElement x="125" y="55" width="150" height="12"/>
                <textFieldExpression><![CDATA[$F{bankAccountType}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="300" y="25" width="120" height="12"/>
                <textElement>
                    <font fontName="Garamond" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Account Number:]]></text>
            </staticText>
            <textField>
                <reportElement x="425" y="25" width="120" height="12"/>
                <textFieldExpression><![CDATA[$F{bankAccountNumber}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="300" y="40" width="120" height="12"/>
                <textElement>
                    <font fontName="Garamond" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Branch / Phone:]]></text>
            </staticText>
            <textField>
                <reportElement x="425" y="40" width="120" height="12"/>
                <textFieldExpression><![CDATA[$F{bankBranchPhoneAndName}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- Detail band -->
    <detail>
        <band height="450">
            <!-- Line 1 -->
            <staticText>
                <reportElement x="0" y="0" width="300" height="14"/>
                <textElement>
                    <font fontName="Garamond" size="10"/>
                </textElement>
                <text><![CDATA[1. Balance from bank statement at end of period:]]></text>
            </staticText>
            <textField pattern="###,##0.00">
                <reportElement x="310" y="0" width="120" height="14"/>
                <textElement>
                    <font fontName="Calibri" size="11"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{balanceFromBankStatement}]]></textFieldExpression>
            </textField>

            <!-- Deposits section header with simulated double underline -->
            <staticText>
                <reportElement x="0" y="20" width="400" height="14"/>
                <textElement>
                    <font fontName="Garamond" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[2. Deposits not cleared on statement        ]]></text>
            </staticText>
            <!-- First underline -->
            <line>
                <reportElement x="0" y="35" width="400" height="1"/>
            </line>
            <!-- Second underline slightly below to mimic double -->
            <line>
                <reportElement x="0" y="37" width="400" height="1"/>
            </line>

            <!-- Deposit 1 -->
            <staticText>
                <reportElement x="0" y="50" width="100" height="12"/>
                <textElement>
                    <font fontName="Garamond" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Deposit 1 Date:]]></text>
            </staticText>
            <textField>
                <reportElement x="105" y="50" width="100" height="12"/>
                <textFieldExpression><![CDATA[$F{deposit1Date}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="220" y="50" width="120" height="12"/>
                <textElement>
                    <font fontName="Garamond" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Amount of Deposit 1:]]></text>
            </staticText>
            <textField pattern="###,##0.00">
                <reportElement x="345" y="50" width="100" height="12"/>
                <textFieldExpression><![CDATA[$F{deposit1Amount}]]></textFieldExpression>
            </textField>

            <!-- Deposit 2 -->
            <staticText>
                <reportElement x="0" y="66" width="100" height="12"/>
                <textElement>
                    <font fontName="Garamond" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Deposit 2 Date:]]></text>
            </staticText>
            <textField>
                <reportElement x="105" y="66" width="100" height="12"/>
                <textFieldExpression><![CDATA[$F{deposit2Date}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="220" y="66" width="120" height="12"/>
                <textElement>
                    <font fontName="Garamond" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Amount of Deposit 2:]]></text>
            </staticText>
            <textField pattern="###,##0.00">
                <reportElement x="345" y="66" width="100" height="12"/>
                <textFieldExpression><![CDATA[$F{deposit2Amount}]]></textFieldExpression>
            </textField>

            <!-- (Repeat for deposit3..deposit6 similarly) -->

            <!-- Total Deposits Not Cleared -->
            <staticText>
                <reportElement x="0" y="140" width="220" height="14"/>
                <textElement>
                    <font fontName="Garamond" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Total Deposits Not Cleared:]]></text>
            </staticText>
            <textField pattern="###,##0.00">
                <reportElement x="225" y="140" width="120" height="14"/>
                <textFieldExpression><![CDATA[$F{depositsNotClearedTotal}]]></textFieldExpression>
            </textField>

            <!-- Checks section header with double underline -->
            <staticText>
                <reportElement x="0" y="160" width="400" height="14"/>
                <textElement>
                    <font fontName="Garamond" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[3. Checks not cleared on statement]]></text>
            </staticText>
            <line>
                <reportElement x="0" y="175" width="400" height="1"/>
            </line>
            <line>
                <reportElement x="0" y="177" width="400" height="1"/>
            </line>

            <!-- Check 1 -->
            <staticText>
                <reportElement x="0" y="190" width="80" height="12"/>
                <textElement>
                    <font fontName="Garamond" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Check 1 #:]]></text>
            </staticText>
            <textField>
                <reportElement x="85" y="190" width="80" height="12"/>
                <textFieldExpression><![CDATA[$F{check1Number}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="170" y="190" width="50" height="12"/>
                <textElement>
                    <font fontName="Garamond" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Date:]]></text>
            </staticText>
            <textField>
                <reportElement x="225" y="190" width="80" height="12"/>
                <textFieldExpression><![CDATA[$F{check1Date}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="310" y="190" width="80" height="12"/>
                <textElement>
                    <font fontName="Garamond" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Amount:]]></text>
            </staticText>
            <textField pattern="###,##0.00">
                <reportElement x="395" y="190" width="100" height="12"/>
                <textFieldExpression><![CDATA[$F{check1Amount}]]></textFieldExpression>
            </textField>

            <!-- (Repeat for check2..check16 with proper y-offsets) -->

            <!-- Total Checks Not Cleared -->
            <staticText>
                <reportElement x="0" y="340" width="220" height="14"/>
                <textElement>
                    <font fontName="Garamond" size="10" isBold="true"/>
                </textElement>
                <text><![CDATA[Total Checks Not Cleared:]]></text>
            </staticText>
            <textField pattern="###,##0.00">
                <reportElement x="225" y="340" width="120" height="14"/>
                <textFieldExpression><![CDATA[$F{checksNotClearedTotal}]]></textFieldExpression>
            </textField>

            <!-- Adjusted balance / ledger / difference -->
            <staticText>
                <reportElement x="0" y="360" width="300" height="14"/>
                <textElement>
                    <font fontName="Garamond" size="10"/>
                </textElement>
                <text><![CDATA[4. Adjusted ACCOUNT Balance (Line 1 + Line 2  - Line 3)]]></text>
            </staticText>
            <textField pattern="###,##0.00">
                <reportElement x="310" y="360" width="120" height="14"/>
                <textFieldExpression><![CDATA[$F{adjustedAccountBalance}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="378" width="300" height="14"/>
                <textElement>
                    <font fontName="Garamond" size="10"/>
                </textElement>
                <text><![CDATA[5. Ending LEDGER or REGISTER Balance]]></text>
            </staticText>
            <textField pattern="###,##0.00">
                <reportElement x="310" y="378" width="120" height="14"/>
                <textFieldExpression><![CDATA[$F{endingLedgerOrRegisterBalance}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="396" width="300" height="14"/>
                <textElement>
                    <font fontName="Garamond" size="10"/>
                </textElement>
                <text><![CDATA[Reconciliation Difference:]]></text>
            </staticText>
            <textField pattern="###,##0.00">
                <reportElement x="310" y="396" width="120" height="14"/>
                <textFieldExpression><![CDATA[$F{reconciliationDifference}]]></textFieldExpression>
            </textField>

            <!-- Interest question -->
            <staticText>
                <reportElement x="0" y="414" width="400" height="14"/>
                <textElement>
                    <font fontName="Garamond" size="10"/>
                </textElement>
                <text><![CDATA[6. Does this account earn interest? (YES or NO)]]></text>
            </staticText>
            <textField>
                <reportElement x="410" y="414" width="80" height="14"/>
                <textFieldExpression><![CDATA[$F{accountEarnsInterest}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
</jasperReport>
