<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:c="http://jasperreports.sourceforge.net/jasperreports/components"
  xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd
                      http://jasperreports.sourceforge.net/jasperreports/components http://jasperreports.sourceforge.net/xsd/components.xsd"
  name="EXPENSE_DTL_12a_ROW_BASED" language="java" pageWidth="1947" pageHeight="1067"
  columnWidth="1947" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" whenNoDataType="AllSectionsNoDetail">

  <!-- Styles -->
  <style name="SectionHeader" fontName="Garamond" fontSize="12" isBold="true"/>
  <style name="ColumnHeader" fontName="Garamond" fontSize="10" isBold="true"/>
  <style name="Cell" fontName="Garamond" fontSize="10"/>
  <style name="TotalLabel" fontName="Garamond" fontSize="10" isBold="true" isItalic="true"/>
  <style name="TotalValue" fontName="Garamond" fontSize="10"/>

  <!-- Parameters -->
  <parameter name="P_ORG_NAME" class="java.lang.String"/>
  <parameter name="P_REPORT_TITLE" class="java.lang.String"/>
  <parameter name="P_EXP12_ADVERTISING_ROWS" class="java.util.Collection"/>
  <parameter name="P_EXP13_BADDEBTS_ROWS" class="java.util.Collection"/>
  <parameter name="P_EXP17_FEES_ROWS" class="java.util.Collection"/>
  <parameter name="P_TOTAL_12" class="java.math.BigDecimal"/>
  <parameter name="P_TOTAL_13" class="java.math.BigDecimal"/>
  <parameter name="P_TOTAL_17" class="java.math.BigDecimal"/>

  <!-- SubDatasets for row collections -->
  <subDataset name="AdvertisingRows">
    <field name="code" class="java.lang.String"/>
    <field name="organizationOrPeriodical" class="java.lang.String"/>
    <field name="amount" class="java.math.BigDecimal"/>
  </subDataset>

  <subDataset name="BadDebtsRows">
    <field name="code" class="java.lang.String"/>
    <field name="organizationOrPerson" class="java.lang.String"/>
    <field name="reason" class="java.lang.String"/>
    <field name="amount" class="java.math.BigDecimal"/>
  </subDataset>

  <subDataset name="FeesRows">
    <field name="code" class="java.lang.String"/>
    <field name="organizationOrPerson" class="java.lang.String"/>
    <field name="serviceProvided" class="java.lang.String"/>
    <field name="amount" class="java.math.BigDecimal"/>
  </subDataset>

  <title>
    <band height="80">
      <staticText>
        <reportElement x="84" y="10" width="600" height="20"/>
        <textElement>
          <font fontName="Garamond" size="14" isBold="true"/>
        </textElement>
        <text><![CDATA[EXPENSE DETAIL PART 1]]></text>
      </staticText>
      <textField>
        <reportElement x="84" y="35" width="600" height="18"/>
        <textElement>
          <font fontName="Garamond" size="10" isBold="true"/>
        </textElement>
        <textFieldExpression><![CDATA[$P{P_ORG_NAME} + " — " + $P{P_REPORT_TITLE}]]></textFieldExpression>
      </textField>
    </band>
  </title>

  <detail>
    <band height="900">
      <!-- Section 12: Advertising (Non-SCA) -->
      <staticText>
        <reportElement x="84" y="0" width="400" height="18" style="SectionHeader"/>
        <text><![CDATA[12. ADVERTISING (NON-SCA)]]></text>
      </staticText>
      <!-- Column headers -->
      <staticText><reportElement x="84" y="22" width="80" height="16" style="ColumnHeader"/><text><![CDATA[Code]]></text></staticText>
      <staticText><reportElement x="168" y="22" width="440" height="16" style="ColumnHeader"/><text><![CDATA[Organization or Periodical (and date published)]]></text></staticText>
      <staticText><reportElement x="1697" y="22" width="166" height="16" style="ColumnHeader"/><text><![CDATA[Amount]]></text></staticText>

      <!-- Rows via List component -->
      <componentElement>
        <reportElement x="84" y="40" width="1779" height="180"/>
        <c:list>
          <datasetRun subDataset="AdvertisingRows">
            <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.data.JRBeanCollectionDataSource($P{P_EXP12_ADVERTISING_ROWS})]]></dataSourceExpression>
          </datasetRun>
          <c:listContents height="20">
            <textField><reportElement x="0" y="0" width="80" height="18" style="Cell"/><textFieldExpression><![CDATA[$F{code}]]></textFieldExpression></textField>
            <textField isStretchWithOverflow="true"><reportElement x="84" y="0" width="1613" height="18" style="Cell"/><textFieldExpression><![CDATA[$F{organizationOrPeriodical}]]></textFieldExpression></textField>
            <textField><reportElement x="1613" y="0" width="166" height="18" style="Cell"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression></textField>
          </c:listContents>
        </c:list>
      </componentElement>
      <!-- Total -->
      <staticText><reportElement x="84" y="225" width="300" height="16" style="TotalLabel"/><text><![CDATA[Show TOTAL on Pg. 4 Line 12]]></text></staticText>
      <textField><reportElement x="1697" y="225" width="166" height="16" style="TotalValue"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{P_TOTAL_12}]]></textFieldExpression></textField>

      <!-- Section 13: Bad Debts -->
      <staticText>
        <reportElement x="84" y="260" width="400" height="18" style="SectionHeader"/>
        <text><![CDATA[13. BAD DEBTS]]></text>
      </staticText>
      <!-- Column headers -->
      <staticText><reportElement x="84" y="282" width="80" height="16" style="ColumnHeader"/><text><![CDATA[Code]]></text></staticText>
      <staticText><reportElement x="168" y="282" width="280" height="16" style="ColumnHeader"/><text><![CDATA[Organization or Person]]></text></staticText>
      <staticText><reportElement x="452" y="282" width="1225" height="16" style="ColumnHeader"/><text><![CDATA[Reason]]></text></staticText>
      <staticText><reportElement x="1697" y="282" width="166" height="16" style="ColumnHeader"/><text><![CDATA[Amount]]></text></staticText>
      <!-- Rows -->
      <componentElement>
        <reportElement x="84" y="300" width="1779" height="180"/>
        <c:list>
          <datasetRun subDataset="BadDebtsRows">
            <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.data.JRBeanCollectionDataSource($P{P_EXP13_BADDEBTS_ROWS})]]></dataSourceExpression>
          </datasetRun>
          <c:listContents height="20">
            <textField><reportElement x="0" y="0" width="80" height="18" style="Cell"/><textFieldExpression><![CDATA[$F{code}]]></textFieldExpression></textField>
            <textField isStretchWithOverflow="true"><reportElement x="84" y="0" width="260" height="18" style="Cell"/><textFieldExpression><![CDATA[$F{organizationOrPerson}]]></textFieldExpression></textField>
            <textField isStretchWithOverflow="true"><reportElement x="348" y="0" width="1329" height="18" style="Cell"/><textFieldExpression><![CDATA[$F{reason}]]></textFieldExpression></textField>
            <textField><reportElement x="1613" y="0" width="166" height="18" style="Cell"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression></textField>
          </c:listContents>
        </c:list>
      </componentElement>
      <staticText><reportElement x="84" y="485" width="300" height="16" style="TotalLabel"/><text><![CDATA[Show TOTAL on Pg. 4 Line 13]]></text></staticText>
      <textField><reportElement x="1697" y="485" width="166" height="16" style="TotalValue"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{P_TOTAL_13}]]></textFieldExpression></textField>

      <!-- Section 17: Fees & Honoraria -->
      <staticText>
        <reportElement x="84" y="520" width="400" height="18" style="SectionHeader"/>
        <text><![CDATA[17. FEES & HONORARIA]]></text>
      </staticText>
      <!-- Column headers -->
      <staticText><reportElement x="84" y="542" width="80" height="16" style="ColumnHeader"/><text><![CDATA[Code]]></text></staticText>
      <staticText><reportElement x="168" y="542" width="280" height="16" style="ColumnHeader"/><text><![CDATA[Organization or Person]]></text></staticText>
      <staticText><reportElement x="452" y="542" width="1225" height="16" style="ColumnHeader"/><text><![CDATA[Service Provided]]></text></staticText>
      <staticText><reportElement x="1697" y="542" width="166" height="16" style="ColumnHeader"/><text><![CDATA[Amount]]></text></staticText>

      <componentElement>
        <reportElement x="84" y="560" width="1779" height="180"/>
        <c:list>
          <datasetRun subDataset="FeesRows">
            <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.data.JRBeanCollectionDataSource($P{P_EXP17_FEES_ROWS})]]></dataSourceExpression>
          </datasetRun>
          <c:listContents height="20">
            <textField><reportElement x="0" y="0" width="80" height="18" style="Cell"/><textFieldExpression><![CDATA[$F{code}]]></textFieldExpression></textField>
            <textField isStretchWithOverflow="true"><reportElement x="84" y="0" width="260" height="18" style="Cell"/><textFieldExpression><![CDATA[$F{organizationOrPerson}]]></textFieldExpression></textField>
            <textField isStretchWithOverflow="true"><reportElement x="348" y="0" width="1329" height="18" style="Cell"/><textFieldExpression><![CDATA[$F{serviceProvided}]]></textFieldExpression></textField>
            <textField><reportElement x="1613" y="0" width="166" height="18" style="Cell"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression></textField>
          </c:listContents>
        </c:list>
      </componentElement>
      <staticText><reportElement x="84" y="745" width="300" height="16" style="TotalLabel"/><text><![CDATA[Show TOTAL on Pg. 4 Line 17]]></text></staticText>
      <textField><reportElement x="1697" y="745" width="166" height="16" style="TotalValue"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{P_TOTAL_17}]]></textFieldExpression></textField>
    </band>
