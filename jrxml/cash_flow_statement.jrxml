<!-- Created with Jaspersoft Studio version 7.0.3.final using JasperReports Library version 7.0.3-41034ca841d452f3305ba55b9042260aaa1ab5dd  -->
<jasperReport whenNoDataType="AllSectionsNoDetail" name="CashFlowStatement" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<parameter name="P_REPORT_TITLE" class="java.lang.String"/>
	<parameter name="P_COMPANY_NAME" class="java.lang.String"/>
	<parameter name="P_REPORT_PERIOD" class="java.lang.String"/>
	<parameter name="P_GENERATION_DATE" class="java.lang.String"/>
	<field name="section_name" class="java.lang.String"/>
	<field name="item_description" class="java.lang.String"/>
	<field name="item_amount" class="java.math.BigDecimal"/>
	<group name="SectionGroup">
		<expression><![CDATA[$F{section_name}]]></expression>
		<groupHeader>
			<band height="25">
				<element kind="textField" x="0" y="5" width="555" height="20" fontSize="12.0" bold="true">
					<expression><![CDATA[$F{section_name}]]></expression>
				</element>
			</band>
		</groupHeader>
		<groupFooter>
			<band height="5"/>
		</groupFooter>
	</group>
	<title height="70">
		<element kind="textField" x="0" y="0" width="555" height="30" fontSize="16.0" bold="true" hTextAlign="Center" vTextAlign="Middle">
			<expression><![CDATA[$P{P_REPORT_TITLE}]]></expression>
		</element>
		<element kind="textField" x="0" y="30" width="555" height="20" hTextAlign="Center" vTextAlign="Middle">
			<expression><![CDATA[$P{P_COMPANY_NAME}]]></expression>
		</element>
		<element kind="textField" x="0" y="50" width="555" height="20" hTextAlign="Center" vTextAlign="Middle">
			<expression><![CDATA[$P{P_REPORT_PERIOD}]]></expression>
		</element>
	</title>
	<pageHeader height="20">
		<element kind="staticText" x="50" y="0" width="350" height="20">
			<text><![CDATA[Description]]></text>
		</element>
		<element kind="staticText" x="400" y="0" width="155" height="20" hTextAlign="Right">
			<text><![CDATA[Amount]]></text>
		</element>
	</pageHeader>
	<detail>
		<band height="20">
			<element kind="textField" x="50" y="0" width="350" height="20" textAdjust="StretchHeight">
				<expression><![CDATA[$F{item_description}]]></expression>
			</element>
			<element kind="textField" x="400" y="0" width="155" height="20" pattern="#,##0.00" hTextAlign="Right">
				<expression><![CDATA[$F{item_amount}]]></expression>
			</element>
		</band>
	</detail>
	<pageFooter height="20">
		<element kind="textField" x="455" y="0" width="100" height="20" hTextAlign="Right">
			<expression><![CDATA["Page " + $V{PAGE_NUMBER}]]></expression>
		</element>
		<element kind="textField" x="0" y="0" width="200" height="20">
			<expression><![CDATA["Generated: " + $P{P_GENERATION_DATE}]]></expression>
		</element>
	</pageFooter>
	<summary height="30"/>
</jasperReport>
