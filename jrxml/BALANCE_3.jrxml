<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="BALANCE_3_FULL"
              language="java"
              pageWidth="595" pageHeight="842"
              columnWidth="555"
              leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20"
              whenNoDataType="AllSectionsNoDetail"
              uuid="f50c6b2f-0c9d-4f34-b586-4ed56c42b5de">

  <!-- Parameters -->
  <parameter name="P_ORG_NAME"     class="java.lang.String"/>
  <parameter name="P_REPORT_TITLE" class="java.lang.String"/>

  <!-- Dynamic fields (BigDecimal) -->
  <!--  … all Start / End fields for assets & liabilities … -->
  <field name="undepositedCashStart"        class="java.math.BigDecimal"/>
  <field name="undepositedCashEnd"          class="java.math.BigDecimal"/>
  <field name="cashEarningInterestStart"    class="java.math.BigDecimal"/>
  <field name="cashEarningInterestEnd"      class="java.math.BigDecimal"/>
  <field name="receivablesStart"            class="java.math.BigDecimal"/>
  <field name="receivablesEnd"              class="java.math.BigDecimal"/>
  <field name="inventoryForSaleStart"       class="java.math.BigDecimal"/>
  <field name="inventoryForSaleEnd"         class="java.math.BigDecimal"/>
  <field name="regaliaEquipmentStart"       class="java.math.BigDecimal"/>
  <field name="regaliaEquipmentEnd"         class="java.math.BigDecimal"/>
  <field name="depreciatedEquipmentStart"   class="java.math.BigDecimal"/>
  <field name="depreciatedEquipmentEnd"     class="java.math.BigDecimal"/>
  <field name="accumulatedDepreciationStart"class="java.math.BigDecimal"/>
  <field name="accumulatedDepreciationEnd"  class="java.math.BigDecimal"/>
  <field name="prepaidExpensesStart"        class="java.math.BigDecimal"/>
  <field name="prepaidExpensesEnd"          class="java.math.BigDecimal"/>
  <field name="otherAssetsStart"            class="java.math.BigDecimal"/>
  <field name="otherAssetsEnd"              class="java.math.BigDecimal"/>
  <field name="totalAssetsStart"            class="java.math.BigDecimal"/>
  <field name="totalAssetsEnd"              class="java.math.BigDecimal"/>

  <field name="newsletterSubsDueStart"      class="java.math.BigDecimal"/>
  <field name="newsletterSubsDueEnd"        class="java.math.BigDecimal"/>
  <field name="deferredRevenueStart"        class="java.math.BigDecimal"/>
  <field name="deferredRevenueEnd"          class="java.math.BigDecimal"/>
  <field name="payablesStart"               class="java.math.BigDecimal"/>
  <field name="payablesEnd"                 class="java.math.BigDecimal"/>
  <field name="otherLiabilitiesStart"       class="java.math.BigDecimal"/>
  <field name="otherLiabilitiesEnd"         class="java.math.BigDecimal"/>
  <field name="totalLiabilitiesStart"       class="java.math.BigDecimal"/>
  <field name="totalLiabilitiesEnd"         class="java.math.BigDecimal"/>

  <field name="netWorthStart"               class="java.math.BigDecimal"/>
  <field name="netWorthEnd"                 class="java.math.BigDecimal"/>

  <!-- Proof -->
  <field name="changeInNetWorth"            class="java.math.BigDecimal"/>
  <field name="netIncome"                   class="java.math.BigDecimal"/>

  <!-- ===== Title band ===== -->
  <title>
    <band height="40">
      <textField>
        <reportElement x="0" y="0" width="555" height="18"/>
        <textElement textAlignment="Center"><font size="14" isBold="true"/></textElement>
        <textFieldExpression><![CDATA[$P{P_ORG_NAME}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="0" y="18" width="555" height="18"/>
        <textElement textAlignment="Center"><font size="12"/></textElement>
        <textFieldExpression><![CDATA[$P{P_REPORT_TITLE}]]></textFieldExpression>
      </textField>
    </band>
  </title>

  <!-- ===== Detail band (assets, liabilities, net worth, proof) ===== -->
  <detail>
    <band height="800">
      <!-- Section I. ASSETS header -->
      <staticText><reportElement x="0" y="0" width="200" height="16"/><text><![CDATA[I.  ASSETS]]></text></staticText>

      <!-- One static/dynamic row per asset line (adds Start + End fields) -->
      <!-- Undeposited Cash -->
      <staticText><reportElement x="0" y="16" width="190" height="16"/><text><![CDATA[Undeposited and Non-Interest Bearing Cash]]></text></staticText>
      <textField pattern="#,##0.00"><reportElement x="200" y="16" width="80" height="16"/><textFieldExpression><![CDATA[$F{undepositedCashStart}]]></textFieldExpression></textField>
      <textField pattern="#,##0.00"><reportElement x="350" y="16" width="80" height="16"/><textFieldExpression><![CDATA[$F{undepositedCashEnd}]]></textFieldExpression></textField>

      <!-- Cash Earning Interest -->
      <staticText><reportElement x="0" y="32" width="190" height="16"/><text><![CDATA[Cash Earning Interest]]></text></staticText>
      <textField pattern="#,##0.00"><reportElement x="200" y="32" width="80" height="16"/><textFieldExpression><![CDATA[$F{cashEarningInterestStart}]]></textFieldExpression></textField>
      <textField pattern="#,##0.00"><reportElement x="350" y="32" width="80" height="16"/><textFieldExpression><![CDATA[$F{cashEarningInterestEnd}]]></textFieldExpression></textField>

      <!-- … repeat rows for each asset & liability … -->

      <!-- Proof section -->
      <staticText><reportElement x="0" y="320" width="60" height="16"/><text><![CDATA[Proof:]]></text></staticText>
      <staticText><reportElement x="60" y="320" width="140" height="16"/><text><![CDATA[Change in Net Worth]]></text></staticText>
      <textField pattern="#,##0.00"><reportElement x="350" y="320" width="80" height="16"/><textFieldExpression><![CDATA[$F{changeInNetWorth}]]></textFieldExpression></textField>

      <staticText><reportElement x="60" y="336" width="140" height="16"/><text><![CDATA[Net Income]]></text></staticText>
      <textField pattern="#,##0.00"><reportElement x="350" y="336" width="80" height="16"/><textFieldExpression><![CDATA[$F{netIncome}]]></textFieldExpression></textField>
    </band>
  </detail>
</jasperReport>