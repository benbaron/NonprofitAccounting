Report: Account Activity Detail
Report Period: ${reportStartDate} to ${reportEndDate}
Generated On: ${reportDate}

<jx:forEach items="${accountsDetail}" var="accountData">
Account: ${accountData.accountName} (${accountData.accountNumber})
Opening Balance: ${accountData.openingBalance}

| Date       | Transaction ID | Description          | Debit      | Credit     | Running Balance |
|------------|----------------|----------------------|------------|------------|-----------------|
<jx:forEach items="${accountData.entries}" var="entry">
| ${entry.date} | ${entry.transactionId} | ${entry.description} | ${entry.debit} | ${entry.credit} | ${entry.runningBalance} |
</jx:forEach>
Closing Balance: ${accountData.closingBalance}

----------------------------------------------------
</jx:forEach>
