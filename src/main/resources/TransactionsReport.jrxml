<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="TransactionsReport"
              language="java"
              pageWidth="595"
              pageHeight="842"
              leftMargin="70"
              rightMargin="70"
              topMargin="70"
              bottomMargin="70"
              columnWidth="540">

    <!-- Title Section (Report Header) -->
    <title>
        <band height="110">
            <textField>
                <reportElement x="55%" y="1" width="45%" height="16" alignment="right"/>
                <textFieldExpression><![CDATA["Transactions Report"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="1" width="50%" height="16" alignment="left"/>
                <textFieldExpression><![CDATA["Report Title"]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="18" width="540" height="2" forecolor="#000000"/>
            </line>
            <image>
                <reportElement x="250" y="21" width="100%" height="67"/>
                <imageExpression><![CDATA[$F{iconheader}]]></imageExpression>
            </image>
            <textField>
                <reportElement x="1" y="19" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{reportdate}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="19" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{dateToday}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="29" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{companytext}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="29" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{company}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="39" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{startdatetext}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="39" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{dateFrom}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="49" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{stopdatetext}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="49" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{dateTo}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="59" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{transfromtext}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="59" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{transfrom}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="69" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{transtotext}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="69" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{transto}]]></textFieldExpression>
            </textField>
            <label  x="120" y="79" width="238" height="10" alignment="left"/>
            <line name="linerepheadbottom" x1="0" y1="90" x2="0" y2="90" weight="3.0"/>
        </band>
    </title>

    <!-- Page Footer (Including page number and date) -->
    <pageFooter>
        <band height="18">
            <textField>
                <reportElement x="50%" y="4" width="100%" height="18" alignment="right"/>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER} + " of " + $V{PAGE_COUNT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="4" width="100" height="18" alignment="left"/>
                <textFieldExpression><![CDATA[$F{dateToday}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <!-- Transaction Group -->
    <group name="Transaction Group">
        <groupHeader>
            <band height="32">
                <textField>
                    <reportElement x="1" y="1" width="39" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{act_id}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="1" y="9" width="39" height="9" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{ACT_ID}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="40" y="1" width="60" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{invdate}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="40" y="9" width="60" height="9" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{INVDATE}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="100" y="1" width="150" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{comment}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="100" y="9" width="150" height="9" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{COMMENTALL}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="250" y="1" width="150" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{fileinfo}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="250" y="9" width="150" height="9" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{FILEINFO}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="400" y="1" width="68" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{regdate}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="400" y="9" width="68" height="9" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{REGDATE}]]></textFieldExpression>
                </textField>
                <line name="line1" x1="0" y1="20" x2="0" y2="20" weight="0.5"/>
                <textField>
                    <reportElement x="0" y="22" width="39" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{accnum}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="40" y="22" width="109" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{accname}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="150" y="22" width="59" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{customer}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="210" y="22" width="89" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{comment}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="300" y="22" width="76" height="7" alignment="right"/>
                    <textFieldExpression><![CDATA[$F{debit}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="400" y="22" width="76" height="7" alignment="right"/>
                    <textFieldExpression><![CDATA[$F{credit}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>

        <groupFooter>
            <band height="25">
                <line name="line1" x1="300" y1="0" x2="475" y2="0" weight="0.5"/>
                <textField x="300" y="3" width="76" height="10" alignment="right" fieldname="FDebitSum"/>
                <textField x="400" y="3" width="76" height="10" alignment="right" fieldname="FCreditSum"/>
            </band>
        </groupFooter>
    </group>

    <!-- Transaction Data Rows -->
    <detail>
        <band height="10">
            <textField x="0" y="0" width="39" height="8" alignment="left" fieldname="ACCOUNTNUM"/>
            <textField x="40" y="0" width="109" height="8" alignment="left" fieldname="ACCOUNTNAME"/>
            <textField x="150" y="0" width="59" height="8" alignment="left" fieldname="CUSTOMER"/>
            <textField x="210" y="0" width="89" height="8" alignment="left" fieldname="COMMENT"/>
            <textField x="300" y="0" width="76" height="8" alignment="right" fieldname="DEBITFORMAT"/>
            <textField x="400" y="0" width="76" height="8" alignment="right" fieldname="CREDITFORMAT"/>
        </band>
    </detail>

    <functions>
        <function name="DebitSum" class="org.jfree.report.function.TotalGroupSumFunction">
            <properties>
                <property name="field">DEBIT</property>
                <property name="group">Transaction Group</property>
            </properties>
        </function>
        <function name="CreditSum" class="org.jfree.report.function.TotalGroupSumFunction">
            <properties>
                <property name="field">CREDIT</property>
                <property name="group">Transaction Group</property>
            </properties>
        </function>

        <expression name="FCreditSum" class="nu.lazy8.util.help.DoubleExpression">
            <properties>
                <property name="doublevalue">CreditSum</property>
            </properties>
        </expression>
        <expression name="FDebitSum" class="nu.lazy8.util.help.DoubleExpression">
            <properties>
                <property name="doublevalue">DebitSum</property>
            </properties>
        </expression>

        <function name="PageNumber" class="org.jfree.report.function.PageFunction"/>
        <function name="PageTotal" class="org.jfree.report.function.PageTotalFunction"/>
        <expression name="pageXofY" class="org.jfree.report.function.TextFormatExpression">
            <properties>
                <property name="pattern">Page {0} ({1})</property>
                <property name="0">PageNumber</property>
                <property name="1">PageTotal</property>
            </properties>
        </expression>
    </functions>

</jasperReport>
