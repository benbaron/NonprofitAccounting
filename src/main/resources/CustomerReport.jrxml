<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="CustomerProjectReport"
              language="java"
              pageWidth="595"
              pageHeight="842"
              leftMargin="70"
              rightMargin="70"
              topMargin="70"
              bottomMargin="70"
              columnWidth="540">

    <!-- Title Section (Report Header) -->
    <title>
        <band height="110">
            <textField>
                <reportElement x="55%" y="1" width="45%" height="16" alignment="right"/>
                <textFieldExpression><![CDATA["Customer/Project Report"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="1" width="50%" height="16" alignment="left"/>
                <textFieldExpression><![CDATA["Report Title"]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="18" width="540" height="2" forecolor="#000000"/>
            </line>
            <image>
                <reportElement x="250" y="21" width="100%" height="67"/>
                <imageExpression><![CDATA[$F{iconheader}]]></imageExpression>
            </image>
            <textField>
                <reportElement x="1" y="19" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{reportdate}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="19" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{dateToday}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="29" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{companytext}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="29" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{company}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- Page Footer (Including page number and date) -->
    <pageFooter>
        <band height="18">
            <textField>
                <reportElement x="50%" y="4" width="100%" height="18" alignment="right"/>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER} + " of " + $V{PAGE_COUNT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="4" width="100" height="18" alignment="left"/>
                <textFieldExpression><![CDATA[$F{dateToday}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <!-- Customer/Project Group -->
    <group name="JUST_A_HEADER_Group">
        <groupHeader>
            <band height="14">
                <textField>
                    <reportElement x="1" y="1" width="79" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{custid}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="80" y="1" width="149" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{custname}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="230" y="1" width="149" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{custdesc}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="380" y="1" width="100%" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{defaultacc}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
        <groupFooter>
            <band height="25"/>
        </groupFooter>
    </group>

    <!-- Customer/Project Data Rows -->
    <detail>
        <band height="10">
            <textField>
                <reportElement x="0" y="0" width="39" height="8" alignment="left"/>
                <textFieldExpression><![CDATA[$F{CUSTNUM}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="80" y="0" width="149" height="8" alignment="left"/>
                <textFieldExpression><![CDATA[$F{CUSTNAME}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="230" y="0" width="149" height="8" alignment="left"/>
                <textFieldExpression><![CDATA[$F{CUSTDESC}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="380" y="0" width="100%" height="8" alignment="left"/>
                <textFieldExpression><![CDATA[$F{DEFAULTAPP}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- Functions (Page Number) -->
    <functions>
        <function name="PageNumber" class="org.jfree.report.function.PageFunction"/>
        <function name="PageTotal" class="org.jfree.report.function.PageTotalFunction"/>
        <expression name="pageXofY" class="org.jfree.report.function.TextFormatExpression">
            <properties>
                <property name="pattern">Page {0} ({1})</property>
                <property name="0">PageNumber</property>
                <property name="1">PageTotal</property>
            </properties>
        </expression>
        <property-ref name="dateToday"/>
        <property-ref name="reporttitle"/>
        <property-ref name="customerreport"/>
        <property-ref name="custid"/>
        <property-ref name="custname"/>
        <property-ref name="defaultacc"/>
        <property-ref name="company"/>
        <property-ref name="companytext"/>
        <property-ref name="custdesc"/>
        <property-ref name="iconheader"/>
        <property-ref name="reportdate"/>
    </functions>
</jasperReport>
