        { "type": "valueRow", "line": "", "label": "Total Net Assets", "valueKey": "workbookSummary.totalNetAssets", "format": "currency" },
        { "type": "valueRow", "line": "", "label": "Net Income / Loss", "valueKey": "workbookSummary.netIncomeLoss", "format": "currency" },
        { "type": "valueRow", "line": "", "label": "Balance Check", "valueKey": "workbookSummary.balanceCheck", "format": "currency", "emphasis": true }
