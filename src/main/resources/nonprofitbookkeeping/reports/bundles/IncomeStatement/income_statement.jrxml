    <parameter name="P_REPORT_TITLE" class="java.lang.String"/>
    <parameter name="P_COMPANY_NAME" class="java.lang.String"/>
    <parameter name="P_REPORT_PERIOD" class="java.lang.String"/>
    <parameter name="P_GENERATION_DATE" class="java.lang.String"/>
    <field name="account_category" class="java.lang.String"/>
    <field name="account_name" class="java.lang.String"/>
    <field name="amount" class="java.math.BigDecimal"/>
    <title>
        <band height="60">
            <textField>
                <reportElement x="0" y="0" width="515" height="20"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{P_REPORT_TITLE} != null ? $P{P_REPORT_TITLE} : "Income Statement"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="20" width="515" height="15"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$P{P_COMPANY_NAME}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="35" width="515" height="15"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$P{P_REPORT_PERIOD}]]></textFieldExpression>
            </textField>
        </band>
    </title>
    <columnHeader>
        <band height="20">
            <staticText>
                <reportElement x="0" y="0" width="180" height="20"/>
                <text><![CDATA[Category]]></text>
            </staticText>
            <staticText>
                <reportElement x="180" y="0" width="235" height="20"/>
