			<element kind="staticText" uuid="57465185-0998-477e-8f7e-ad2dc476b76a" x="20" y="130" width="74" height="12" fontSize="8.0">
				<text><![CDATA[Undeposited funds are cash or checks not yet deposited into an account, and the amount of any temporary cash funds that may exist.]]></text>
			</element>
			<element kind="staticText" uuid="43d84d37-5175-40d3-8bbc-738b1052cbc7" x="20" y="142" width="74" height="12" fontSize="8.0">
				<text><![CDATA[Enter the total amount below with the reason it is not in a bank.]]></text>
			</element>
			<element kind="staticText" uuid="0605a4d4-d954-47fb-b4d6-ef30a4752e31" x="20" y="154" width="74" height="12" fontSize="8.0">
				<text><![CDATA[4th quarter only: Also enter any undeposited transfer checks written in prior year.]]></text>
			</element>
