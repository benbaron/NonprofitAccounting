			</element>
			<element kind="staticText" uuid="1c3d5f47-9b56-4d0f-b9fb-ad412fa3df5c" x="59" y="115" width="72" height="15" fontSize="12.0">
				<text><![CDATA[LIABILITY DETAIL WORKSHEET]]></text>
			</element>
			<element kind="staticText" uuid="78118beb-e3cf-43af-bbe7-a38d581ae7cd" x="59" y="143" width="72" height="13" fontSize="8.0">
				<text><![CDATA[Deferred Revenue is event income that has been collected before the end of the period for an event that will occur after the end]]></text>
			</element>
			<element kind="staticText" uuid="ada039a4-8227-4e90-b445-2559dc37e878" x="59" y="156" width="72" height="13" fontSize="8.0">
				<text><![CDATA[of the period. For the report before the event, enter the name of the event, and any event income collected as the current amount. ]]></text>
			</element>
			<element kind="staticText" uuid="99288664-6d0e-4fd3-b092-d12b28d01754" x="59" y="169" width="72" height="13" fontSize="8.0">
				<text><![CDATA[For the report after the event, move the amount to the prior amount and zero out the current amount for that event.]]></text>
			</element>
			<element kind="staticText" uuid="171533fa-2c80-4cfd-9dd3-75054ce1cddb" x="59" y="182" width="72" height="13" fontSize="8.0">
				<text><![CDATA[For example, Alabaster Alley's 12th night event accepts reservations in December. Any funds received in December would be ]]></text>
			</element>
			<element kind="staticText" uuid="f0cc6929-2392-4091-b26d-03af95db504a" x="59" y="195" width="72" height="13" fontSize="8.0">
				<text><![CDATA[reported as Current Deferred Revenue on the 4th quarter report, and Prior Deferred Revenue on the 1st quarter report next year.]]></text>
			</element>
			<element kind="staticText" uuid="0d98c5ba-b7e3-4a8e-91ff-48f522079d2d" x="59" y="208" width="72" height="13" fontSize="8.0">
				<text><![CDATA[DEFERRED REVENUE:  Event]]></text>
			</element>
