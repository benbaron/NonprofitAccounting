              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="TrialBalance" pageWidth="595" pageHeight="842"
              columnWidth="515" leftMargin="40" rightMargin="40"
              topMargin="40" bottomMargin="40" uuid="bb9314c5-5fb0-4bd0-9b3b-5b3b9878d6e2">
    <parameter name="P_REPORT_TITLE" class="java.lang.String"/>
    <parameter name="P_COMPANY_NAME" class="java.lang.String"/>
    <parameter name="P_AS_OF_DATE" class="java.lang.String"/>
    <parameter name="P_GENERATION_DATE" class="java.lang.String"/>
    <field name="accnum" class="java.lang.String"/>
    <field name="accname" class="java.lang.String"/>
    <field name="incomming" class="java.math.BigDecimal"/>
    <field name="outgoing" class="java.math.BigDecimal"/>
    <field name="amount" class="java.math.BigDecimal"/>
    <title>
        <band height="60">
            <textField>
                <reportElement x="0" y="0" width="515" height="20"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{P_REPORT_TITLE} != null ? $P{P_REPORT_TITLE} : "Trial Balance"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="20" width="515" height="15"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$P{P_COMPANY_NAME}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="35" width="515" height="15"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$P{P_AS_OF_DATE}]]></textFieldExpression>
            </textField>
        </band>
    </title>
    <columnHeader>
        <band height="20">
            <staticText>
                <reportElement x="0" y="0" width="120" height="20"/>
                <text><![CDATA[Account #]]></text>
            </staticText>
            <staticText>
                <reportElement x="120" y="0" width="200" height="20"/>
                <text><![CDATA[Account Name]]></text>
            </staticText>
            <staticText>
                <reportElement x="320" y="0" width="65" height="20"/>
                <text><![CDATA[Debit]]></text>
            </staticText>
            <staticText>
                <reportElement x="385" y="0" width="65" height="20"/>
                <text><![CDATA[Credit]]></text>
            </staticText>
            <staticText>
                <reportElement x="450" y="0" width="65" height="20"/>
                <text><![CDATA[Net]]></text>
            </staticText>
        </band>
    </columnHeader>
    <detail>
        <band height="18">
            <textField>
                <reportElement x="0" y="0" width="120" height="18"/>
                <textFieldExpression><![CDATA[$F{accnum}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="0" width="200" height="18"/>
                <textFieldExpression><![CDATA[$F{accname}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="320" y="0" width="65" height="18"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$F{incomming}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="385" y="0" width="65" height="18"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$F{outgoing}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="450" y="0" width="65" height="18"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
