<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="
                 http://jasperreports.sourceforge.net/jasperreports
                 http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="BalanceResultReport"
              pageWidth="595" pageHeight="842"
              leftMargin="70" rightMargin="70"
              topMargin="70" bottomMargin="70"
              columnWidth="455">

    <!-- ========== FIELDS ========== -->
    <field name="balanseresultreport"          class="java.lang.String"/>
    <field name="reporttitle"                  class="java.lang.String"/>
    <field name="iconheader"                   class="java.lang.Object"/>
    <field name="reportdate"                   class="java.lang.String"/>
    <field name="dateToday"                    class="java.lang.String"/>
    <field name="companytext"                  class="java.lang.String"/>
    <field name="company"                      class="java.lang.String"/>
    <field name="startdatetext"                class="java.lang.String"/>
    <field name="dateFrom"                     class="java.lang.String"/>
    <field name="stopdatetext"                 class="java.lang.String"/>
    <field name="dateTo"                       class="java.lang.String"/>
    <field name="LastTransactionNumberText"    class="java.lang.String"/>
    <field name="LastTransactionNumber"        class="java.lang.String"/>
    <field name="REPORTNAME"                   class="java.lang.String"/>
    <field name="ACCOUNTTYPE"                  class="java.lang.String"/>
    <field name="accnum"                       class="java.lang.String"/>
    <field name="accname"                      class="java.lang.String"/>
    <field name="incomming"                    class="java.lang.Double"/>
    <field name="amount"                       class="java.lang.Double"/>
    <field name="outgoing"                     class="java.lang.Double"/>
    <field name="ACCOUNTNUM"                   class="java.lang.String"/>
    <field name="ACCOUNTDESC"                  class="java.lang.String"/>
    <field name="FORMATED_INCOMMINGAMOUNT"     class="java.lang.String"/>
    <field name="FORMATED_AMOUNT"              class="java.lang.String"/>
    <field name="FORMATED_OUTGOINGAMOUNT"      class="java.lang.String"/>

    <!-- ========== VARIABLES (group‐scoped sums) ========== -->
    <!-- Account Type Group sums -->
    <variable name="IncommingSum"  class="java.lang.Double" calculation="Sum" resetType="Group" resetGroup="AccountTypeGroup">
        <variableExpression><![CDATA[$F{incomming}]]></variableExpression>
    </variable>
    <variable name="AmountSum"     class="java.lang.Double" calculation="Sum" resetType="Group" resetGroup="AccountTypeGroup">
        <variableExpression><![CDATA[$F{amount}]]></variableExpression>
    </variable>
    <variable name="OutgoingSum"   class="java.lang.Double" calculation="Sum" resetType="Group" resetGroup="AccountTypeGroup">
        <variableExpression><![CDATA[$F{outgoing}]]></variableExpression>
    </variable>

    <!-- Report Group sums -->
    <variable name="ReportIncommingSum" class="java.lang.Double" calculation="Sum" resetType="Group" resetGroup="ReportGroup">
        <variableExpression><![CDATA[$F{incomming}]]></variableExpression>
    </variable>
    <variable name="ReportAmountSum"    class="java.lang.Double" calculation="Sum" resetType="Group" resetGroup="ReportGroup">
        <variableExpression><![CDATA[$F{amount}]]></variableExpression>
    </variable>
    <variable name="ReportOutgoingSum"  class="java.lang.Double" calculation="Sum" resetType="Group" resetGroup="ReportGroup">
        <variableExpression><![CDATA[$F{outgoing}]]></variableExpression>
    </variable>

    <!-- ========== GROUP: ReportGroup ========== -->
    <group name="ReportGroup">
        <groupExpression><![CDATA[$F{REPORTNAME}]]></groupExpression>
        <groupHeader>
            <band height="16">
                <textField>
                    <reportElement x="1" y="1" width="453" height="16"/>
                    <textFieldExpression><![CDATA[$F{REPORTNAME}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
        <groupFooter>
            <band height="20">
                <line>
                    <reportElement x="225" y="0" width="250" height="1"/>
                </line>
                <textField>
                    <reportElement x="60"  y="3" width="164" height="10"/>
                    <textFieldExpression><![CDATA[$F{REPORTNAME}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="225" y="3" width="74" height="10"/>
                    <textFieldExpression><![CDATA[$V{ReportIncommingSum}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="300" y="3" width="74" height="10"/>
                    <textFieldExpression><![CDATA[$V{ReportAmountSum}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="375" y="3" width="74" height="10"/>
                    <textFieldExpression><![CDATA[$V{ReportOutgoingSum}]]></textFieldExpression>
                </textField>
            </band>
        </groupFooter>
    </group>

    <!-- ========== GROUP: AccountTypeGroup ========== -->
    <group name="AccountTypeGroup">
        <groupExpression><![CDATA[$F{ACCOUNTTYPE}]]></groupExpression>
        <groupHeader>
            <band height="33">
                <textField>
                    <reportElement x="10" y="1" width="445" height="16"/>
                    <textElement>
                        <font size="12" isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA[$F{ACCOUNTTYPE}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="20" y="22" width="39"  height="7"/>
                    <textFieldExpression><![CDATA[$F{accnum}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="60" y="22" width="164" height="7"/>
                    <textFieldExpression><![CDATA[$F{accname}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="225" y="22" width="74" height="7" forecolor="#000000"/>
                    <textFieldExpression><![CDATA[$F{incomming}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="300" y="22" width="74" height="7"/>
                    <textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="375" y="22" width="74" height="7"/>
                    <textFieldExpression><![CDATA[$F{outgoing}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
        <groupFooter>
            <band height="15">
                <line>
                    <reportElement x="225" y="0" width="250" height="1"/>
                </line>
                <textField>
                    <reportElement x="60" y="3" width="164" height="10"/>
                    <textFieldExpression><![CDATA[$F{ACCOUNTTYPE}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="225" y="3" width="74" height="10"/>
                    <textFieldExpression><![CDATA[$V{IncommingSum}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="300" y="3" width="74" height="10"/>
                    <textFieldExpression><![CDATA[$V{AmountSum}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="375" y="3" width="74" height="10"/>
                    <textFieldExpression><![CDATA[$V{OutgoingSum}]]></textFieldExpression>
                </textField>
            </band>
        </groupFooter>
    </group>

    <!-- ========== TITLE (formerly reportheader) ========== -->
    <title>
        <band height="100">
            <textField>
                <reportElement x="250" y="1" width="205" height="16"/>
                <textElement textAlignment="Right">
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{balanseresultreport}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="1" width="205" height="16"/>
                <textElement>
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{reporttitle}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="18" width="455" height="2"/>
            </line>
            <image>
                <reportElement x="250" y="21" width="100" height="67"/>
                <imageExpression><![CDATA[$F{iconheader}]]></imageExpression>
            </image>
            <textField>
                <reportElement x="1" y="19" width="118" height="10"/>
                <textFieldExpression><![CDATA[$F{reportdate}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="19" width="128" height="10"/>
                <textFieldExpression><![CDATA[$F{dateToday}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="29" width="118" height="10"/>
                <textFieldExpression><![CDATA[$F{companytext}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="29" width="128" height="10"/>
                <textFieldExpression><![CDATA[$F{company}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="39" width="118" height="10"/>
                <textFieldExpression><![CDATA[$F{startdatetext}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="39" width="128" height="10"/>
                <textFieldExpression><![CDATA[$F{dateFrom}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="49" width="118" height="10"/>
                <textFieldExpression><![CDATA[$F{stopdatetext}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="49" width="128" height="10"/>
                <textFieldExpression><![CDATA[$F{dateTo}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="59" width="118" height="10"/>
                <textFieldExpression><![CDATA[$F{LastTransactionNumberText}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="59" width="128" height="10"/>
                <textFieldExpression><![CDATA[$F{LastTransactionNumber}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="90" width="455" height="3"/>
            </line>
        </band>
    </title>

    <!-- ========== PAGE HEADER (empty) ========== -->
    <pageHeader>
        <band height="0"/>
    </pageHeader>

    <!-- ========== COLUMN HEADER (none) ========== -->
    <columnHeader>
        <band height="0"/>
    </columnHeader>

    <!-- ========== DETAIL (formerly items) ========== -->
    <detail>
        <band height="10">
            <textField>
                <reportElement x="20"  y="0" width="40" height="10"/>
                <textFieldExpression><![CDATA[$F{ACCOUNTNUM}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="60"  y="0" width="164" height="10"/>
                <textFieldExpression><![CDATA[$F{ACCOUNTDESC}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="225" y="0" width="75" height="10"/>
                <textFieldExpression><![CDATA[$F{FORMATED_INCOMMINGAMOUNT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="300" y="0" width="75" height="10"/>
                <textFieldExpression><![CDATA[$F{FORMATED_AMOUNT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="375" y="0" width="75" height="10"/>
                <textFieldExpression><![CDATA[$F{FORMATED_OUTGOINGAMOUNT}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- ========== COLUMN FOOTER (none) ========== -->
    <columnFooter>
        <band height="0"/>
    </columnFooter>

    <!-- ========== PAGE FOOTER ========== -->
    <pageFooter>
        <band height="18">
            <textField>
                <reportElement x="50" y="4" width="405" height="18"/>
                <textFieldExpression><![CDATA[
                    "Page " + $V{PAGE_NUMBER} + " of " + $V{PAGE_COUNT}
                ]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="4" width="45%" height="18"/>
                <textFieldExpression><![CDATA[$F{dateToday}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <!-- ========== SUMMARY (empty, your reportfooter was empty) ========== -->
    <summary>
        <band height="48"/>
    </summary>

    <!-- ========== NO DATA SECTION (none) ========== -->
    <noData>
        <band height="30">
            <staticText>
                <reportElement x="0" y="0" width="455" height="30"/>
                <text><![CDATA[No data to display]]></text>
            </staticText>
        </band>
    </noData>
</jasperReport>
