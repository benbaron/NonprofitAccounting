<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="ChartOfAccountsReport"
              language="java"
              pageWidth="595"
              pageHeight="842"
              leftMargin="70"
              rightMargin="70"
              topMargin="70"
              bottomMargin="70"
              columnWidth="540">
              
    <!-- Title Section (Report Header) -->
    <title>
        <band height="110">
            <textField>
                <reportElement x="55%" y="1" width="45%" height="16" alignment="right"/>
                <textFieldExpression><![CDATA["Chart of Accounts"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="1" width="50%" height="16" alignment="left"/>
                <textFieldExpression><![CDATA["Report Title"]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="18" width="540" height="2" forecolor="#000000"/>
            </line>
            <image>
                <reportElement x="250" y="21" width="100%" height="67"/>
                <imageExpression><![CDATA[$F{iconheader}]]></imageExpression>
            </image>
            <textField>
                <reportElement x="1" y="19" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{reportdate}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="19" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{dateToday}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="29" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{companytext}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="29" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{company}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- Page Footer (Including page number and date) -->
    <pageFooter>
        <band height="18">
            <textField>
                <reportElement x="50%" y="4" width="100%" height="18" alignment="right"/>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER} + " of " + $V{PAGE_COUNT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="4" width="100" height="18" alignment="left"/>
                <textFieldExpression><![CDATA[$F{dateToday}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <!-- Detail Section -->
    <detail>
        <band height="10">
            <textField>
                <reportElement x="0" y="0" width="39" height="8" alignment="left"/>
                <textFieldExpression><![CDATA[$F{ACCOUNTNUM}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="40" y="0" width="109" height="8" alignment="left"/>
                <textFieldExpression><![CDATA[$F{ACCOUNTNAME}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="350" y="0" width="100%" height="8" alignment="left"/>
                <textFieldExpression><![CDATA[$F{ACCOUNTTYPE}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- Group for Account Headers -->
    <group name="JUST_A_HEADER_Group">
        <groupHeader>
            <band height="14">
                <textField>
                    <reportElement x="1" y="1" width="39" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{accnum}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="40" y="1" width="309" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{accname}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="350" y="1" width="100%" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{isdebit}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
    </group>

    <!-- Functions (Page Number) -->
    <variable name="PAGE_NUMBER" class="java.lang.Integer" calculation="Sum">
        <variableExpression><![CDATA[$V{PAGE_NUMBER}]]></variableExpression>
    </variable>
    <variable name="PAGE_COUNT" class="java.lang.Integer" calculation="Count">
        <variableExpression><![CDATA[$V{PAGE_COUNT}]]></variableExpression>
    </variable>

    <property name="fontmod" value="nu.lazy8.util.help.FontChangeFunction"/>
</jasperReport>
