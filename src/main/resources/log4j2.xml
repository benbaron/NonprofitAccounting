<Configuration status="DEBUG">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout>
                <Pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger{36} - %msg%n</Pattern>
            </PatternLayout>
        </Console>

        <File name="File" fileName="logs/app.log">
            <PatternLayout>
                <Pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger{36} - %msg%n</Pattern>
            </PatternLayout>
        </File>
    </Appenders>

    <Loggers>
        <Root level="info">
            <AppenderRef ref="Console" />
            <AppenderRef ref="File" />
        </Root>        
        
        <!-- ①  Add one Logger for all Jackson packages -->
	    <Logger name="com.fasterxml.jackson" level="DEBUG" additivity="false">
	        <AppenderRef ref="STDOUT"/>
	    </Logger>
	
	    <!-- (Optional) Finer control per module  
	    <Logger name="com.fasterxml.jackson.databind" level="DEBUG" additivity="false">
	        <AppenderRef ref="STDOUT"/>
	    </Logger>
	    <Logger name="com.fasterxml.jackson.core" level="INFO" additivity="false">
	        <AppenderRef ref="STDOUT"/>
	    </Logger>
	        -->

    <!-- JasperReports engine core logging -->
    <Logger name="net.sf.jasperreports.engine" level="debug" additivity="false">
        <AppenderRef ref="Console"/>
    </Logger>

    <!-- Optional: Fill process -->
    <Logger name="net.sf.jasperreports.engine.fill" level="debug" additivity="false">
        <AppenderRef ref="Console"/>
    </Logger>

    <!-- Optional: Compilation process -->
    <Logger name="net.sf.jasperreports.engine.compile" level="debug" additivity="false">
        <AppenderRef ref="Console"/>
    </Logger>

    <!-- Optional: All JasperReports logs -->
    <Logger name="net.sf.jasperreports" level="debug" additivity="false">
        <AppenderRef ref="Console"/>
    </Logger>

</Loggers>
    
    
    
</Configuration>

