<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="AccountLedger" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">
    <parameter name="P_REPORT_TITLE" class="java.lang.String"/>
    <parameter name="P_COMPANY_NAME" class="java.lang.String"/>
    <parameter name="P_ACCOUNT" class="java.lang.String"/>
    <parameter name="P_REPORT_PERIOD" class="java.lang.String"/>
    <parameter name="P_GENERATION_DATE" class="java.lang.String"/>
    <field name="date" class="java.lang.String"/>
    <field name="description" class="java.lang.String"/>
    <field name="debit" class="java.math.BigDecimal"/>
    <field name="credit" class="java.math.BigDecimal"/>
    <field name="balance" class="java.math.BigDecimal"/>
    <title>
        <band height="50">
            <textField>
                <reportElement x="0" y="0" width="555" height="20"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{P_REPORT_TITLE}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="20" width="555" height="15"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$P{P_COMPANY_NAME}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="35" width="555" height="15"/>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$P{P_ACCOUNT} + " - " + $P{P_REPORT_PERIOD}]]></textFieldExpression>
            </textField>
        </band>
    </title>
    <pageHeader>
        <band height="20">
            <staticText>
                <reportElement x="0" y="0" width="100" height="20"/>
                <text><![CDATA[Date]]></text>
            </staticText>
            <staticText>
                <reportElement x="100" y="0" width="250" height="20"/>
                <text><![CDATA[Description]]></text>
            </staticText>
            <staticText>
                <reportElement x="350" y="0" width="70" height="20"/>
                <textElement textAlignment="Right"/>
                <text><![CDATA[Debit]]></text>
            </staticText>
            <staticText>
                <reportElement x="420" y="0" width="70" height="20"/>
                <textElement textAlignment="Right"/>
                <text><![CDATA[Credit]]></text>
            </staticText>
            <staticText>
                <reportElement x="490" y="0" width="65" height="20"/>
                <textElement textAlignment="Right"/>
                <text><![CDATA[Balance]]></text>
            </staticText>
        </band>
    </pageHeader>
    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="100" height="20"/>
                <textFieldExpression><![CDATA[$F{date}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="100" y="0" width="250" height="20"/>
                <textFieldExpression><![CDATA[$F{description}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="350" y="0" width="70" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$F{debit}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="420" y="0" width="70" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$F{credit}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="490" y="0" width="65" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA[$F{balance}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
    <pageFooter>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="200" height="20"/>
                <textFieldExpression><![CDATA["Generated: " + $P{P_GENERATION_DATE}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="455" y="0" width="100" height="20"/>
                <textElement textAlignment="Right"/>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>
</jasperReport>
