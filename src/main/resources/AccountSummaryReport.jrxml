<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
                                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="AccountSummaryReport"
              language="java"
              pageWidth="595"
              pageHeight="842"
              leftMargin="70"
              rightMargin="70"
              topMargin="70"
              bottomMargin="70"
              columnWidth="540">

    <!-- Title Section -->
    <title>
        <band height="110">
            <textField>
                <reportElement x="55%" y="1" width="45%" height="16" alignment="right"/>
                <textFieldExpression><![CDATA["Account Summary"]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="1" width="50%" height="16" alignment="left"/>
                <textFieldExpression><![CDATA["Report Title"]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="18" width="540" height="2" forecolor="#000000"/>
            </line>
            <image>
                <reportElement x="250" y="20" width="100%" height="67"/>
                <imageExpression><![CDATA[$F{iconheader}]]></imageExpression>
            </image>
            <textField>
                <reportElement x="1" y="19" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{reportdate}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="19" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{dateToday}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="29" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{companytext}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="29" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{company}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="39" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{startdatetext}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="39" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{dateFrom}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="49" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{stopdatetext}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="49" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{dateTo}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="59" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{accnum}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="59" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{selectedaccount}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="69" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{customer}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="69" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{selectedcustomer}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="1" y="79" width="118" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{LastTransactionNumberText}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="79" width="128" height="10" alignment="left"/>
                <textFieldExpression><![CDATA[$F{LastTransactionNumber}]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="90" width="540" height="3" forecolor="#000000"/>
            </line>
        </band>
    </title>

    <!-- Page Footer (Including page number and date) -->
    <pageFooter>
        <band height="18">
            <textField>
                <reportElement x="50%" y="4" width="100%" height="18" alignment="right"/>
                <textFieldExpression><![CDATA["Page " + $V{PAGE_NUMBER} + " of " + $V{PAGE_COUNT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="0" y="4" width="100" height="18" alignment="left"/>
                <textFieldExpression><![CDATA[$F{dateToday}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>

    <!-- Account Group Header -->
    <group name="Account Group">
        <groupHeader>
            <band height="32">
                <textField>
                    <reportElement x="0" y="0" width="39" height="10" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{ACCOUNTNUM}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="40" y="0" width="100%" height="10" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{ACCOUNTNAME}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="0" y="19" width="39" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{act_id}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="40" y="19" width="44" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{invdate}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="85" y="19" width="104" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{comment}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="190" y="19" width="69" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{comment}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="260" y="19" width="39" height="7" alignment="left"/>
                    <textFieldExpression><![CDATA[$F{customer}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="300" y="19" width="76" height="7" alignment="right"/>
                    <textFieldExpression><![CDATA[$F{debit}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="400" y="19" width="76" height="7" alignment="right"/>
                    <textFieldExpression><![CDATA[$F{credit}]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>

        <!-- Group Footer -->
        <groupFooter>
            <band height="45">
                <line>
                    <reportElement x="300" y="0" width="175" height="0.5" forecolor="#000000"/>
                </line>
                <textField>
                    <reportElement x="200" y="3" width="76" height="10" alignment="right"/>
                    <textFieldExpression><![CDATA[$F{Total}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="300" y="3" width="76" height="10" alignment="right"/>
                    <textFieldExpression><![CDATA[$F{FDebitSum}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="400" y="3" width="76" height="10" alignment="right"/>
                    <textFieldExpression><![CDATA[$F{FCreditSum}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="200" y="15" width="76" height="7" alignment="right"/>
                    <textFieldExpression><![CDATA[$F{incomming}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="300" y="15" width="76" height="7" alignment="right"/>
                    <textFieldExpression><![CDATA[$F{amount}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="400" y="15" width="76" height="7" alignment="right"/>
                    <textFieldExpression><![CDATA[$F{outgoing}]]></textFieldExpression>
                </textField>
                <line>
                    <reportElement x="200" y="23" width="275" height="0.5" forecolor="#000000"/>
                </line>
                <textField>
                    <reportElement x="200" y="26" width="76" height="10" alignment="right"/>
                    <textFieldExpression><![CDATA[$F{INCOMMINGAMOUNT}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="300" y="26" width="76" height="10" alignment="right"/>
                    <textFieldExpression><![CDATA[$F{FBalanceSum}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="400" y="26" width="76" height="10" alignment="right"/>
                    <textFieldExpression><![CDATA[$F{OUTGOINGAMOUNT}]]></textFieldExpression>
                </textField>
            </band>
        </groupFooter>
    </group>

    <!-- Detail Section -->
    <detail>
        <band height="10">
            <textField>
                <reportElement x="0" y="0" width="39" height="8" alignment="left"/>
                <textFieldExpression><![CDATA[$F{ACT_ID}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="40" y="0" width="44" height="8" alignment="left"/>
                <textFieldExpression><![CDATA[$F{INVDATE}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="85" y="0" width="104" height="8" alignment="left"/>
                <textFieldExpression><![CDATA[$F{COMMENTALL}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="190" y="0" width="69" height="8" alignment="left"/>
                <textFieldExpression><![CDATA[$F{COMMENT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="260" y="0" width="39" height="8" alignment="left"/>
                <textFieldExpression><![CDATA[$F{CUSTOMER}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="300" y="0" width="76" height="8" alignment="right"/>
                <textFieldExpression><![CDATA[$F{DEBITFORMAT}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="400" y="0" width="76" height="8" alignment="right"/>
                <textFieldExpression><![CDATA[$F{CREDITFORMAT}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- Functions (for totals, page numbers, etc.) -->
    <functions>
        <function name="DebitSum" class="org.jfree.report.function.TotalGroupSumFunction">
            <properties>
                <property name="field">DEBIT</property>
                <property name="group">Account Group</property>
            </properties>
        </function>
        <function name="CreditSum" class="org.jfree.report.function.TotalGroupSumFunction">
            <properties>
                <property name="field">CREDIT</property>
                <property name="group">Account Group</property>
            </properties>
        </function>
        <function name="BalanceSum" class="org.jfree.report.function.TotalGroupSumFunction">
            <properties>
                <property name="field">BALANCE</property>
                <property name="group">Account Group</property>
            </properties>
        </function>
        <expression name="FBalanceSum" class="nu.lazy8.util.help.DoubleExpression">
            <properties>
                <property name="doublevalue">BalanceSum</property>
            </properties>
        </expression>
        <function name="PageNumber" class="org.jfree.report.function.PageFunction"/>
        <function name="PageTotal" class="org.jfree.report.function.PageTotalFunction"/>
        <expression name="pageXofY" class="org.jfree.report.function.TextFormatExpression">
            <properties>
                <property name="pattern">Page {0} ({1})</property>
                <property name="0">PageNumber</property>
                <property name="1">PageTotal</property>
            </properties>
        </expression>
    </functions>
</jasperReport>
